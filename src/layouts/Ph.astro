---
interface Props {
  title: string;
  noAuth?: boolean;
}
const { title = "LustHub - Reproductor", noAuth = false } = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="bg-vs-bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.13/dist/hls.min.js"
    ></script>
  </head>
  <body
    class="min-h-screen w-full max-w-[1600px] mx-auto bg-vs-bg text-gray-300 font-sans p-4 md:p-8"
  >
    <slot />

    <!-- Toggle compartido de los paneles colapsables (.ph-collapsible) en mobile.
         En desktop esos paneles siempre se ven (sm:flex), así que el botón
         #toggle-filters está oculto (sm:hidden) y este script no interfiere. -->
    <script is:inline>
      (function () {
        const btn = document.getElementById("toggle-filters");
        if (!btn) return;
        const panels = document.querySelectorAll(".ph-collapsible");
        const chevron = btn.querySelector("[data-chevron]");
        btn.addEventListener("click", () => {
          const open = panels.length > 0 && panels[0].classList.contains("hidden");
          panels.forEach((el) => el.classList.toggle("hidden", !open));
          btn.setAttribute("aria-expanded", String(open));
          if (chevron) chevron.classList.toggle("rotate-180", open);
        });
      })();
    </script>
  </body>
</html>
