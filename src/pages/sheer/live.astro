---
// Scraper SSR en vivo: en cada request scrapea Sheer (?page=N vía fetch + cookie)
// y renderiza la grilla. Mismos filtros/orden que el catálogo, pero los datos se
// obtienen frescos en el servidor en vez de leer videos.json. Los controles
// (páginas) recargan la página con ?paginas=N.
import Layout from '../../layouts/Sheer.astro';
import SheerVideoCard from '../../components/sheer/SheerVideoCard.astro';
import SheerAuth from '../../components/sheer/SheerAuth.astro';
import { scrapeSheer, DEFAULT_ALIAS } from '../../lib/sheer/scraper.js';

export const prerender = false;

const env = (Astro.locals as any)?.runtime?.env;

const params = Astro.url.searchParams;
const alias = (params.get('alias') || DEFAULT_ALIAS).trim() || DEFAULT_ALIAS;
const pages = Math.min(Math.max(parseInt(params.get('paginas') || '1', 10) || 1, 1), 40);

let videos: any[] = [];
let totalPages = 0;
let error: string | null = null;
const startedAt = Date.now();

try {
  const result = await scrapeSheer({ alias, maxPages: pages, env });
  videos = result.videos;
  totalPages = result.totalPages;
} catch (e: any) {
  error = e.message;
}

const elapsed = ((Date.now() - startedAt) / 1000).toFixed(1);

// Build filter lists (actrices y categorías) from the scraped data
const actressMap = new Map<string, number>();
const categoryMap = new Map<string, { name: string; count: number }>();

videos.forEach((v) => {
  (v.models || []).forEach((m: any) => {
    if (m && m.name) actressMap.set(m.name, (actressMap.get(m.name) || 0) + 1);
  });
  (v.tags || []).forEach((t: any) => {
    const key = (t && (t.alias || t.name)) || '';
    if (!key) return;
    const cur = categoryMap.get(key) || { name: t.name || key, count: 0 };
    cur.count += 1;
    categoryMap.set(key, cur);
  });
});

const actresses = [...actressMap.entries()]
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

const categories = [...categoryMap.entries()]
  .map(([alias, o]) => ({ alias, name: o.name, count: o.count }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

const resolutionSet = new Set<number>();
videos.forEach((v) => (v.sources || []).forEach((s: any) => s.size && resolutionSet.add(Number(s.size))));
const resolutions = [...resolutionSet].sort((a, b) => b - a);

const hasFilters = actresses.length > 0 || categories.length > 0;
---

<Layout title="Scraper en Vivo - Sheer">
  <div class="mx-auto max-w-[1300px] px-4 py-6 sm:px-6 sm:py-8">
    <header class="sticky top-0 z-[100] mb-8 flex flex-wrap items-center justify-between gap-3 border-b border-line bg-[rgba(8,5,15,0.8)] pb-4 backdrop-blur-md sm:mb-12 sm:pb-6">
      <a href="/sheer" class="text-gradient flex items-center gap-2 text-[1.35rem] font-extrabold tracking-[-0.5px] sm:text-[1.8rem]">
        <i class="fa-solid fa-bolt"></i> Sheer en Vivo
      </a>
      <div class="shrink-0 whitespace-nowrap rounded-full border border-line bg-card px-3 py-1.5 text-[0.8rem] text-muted sm:px-4 sm:py-2 sm:text-[0.9rem]">
        {error ? (
          <span class="text-danger"><i class="fa-solid fa-triangle-exclamation"></i> Error</span>
        ) : (
          <span><i class="fa-solid fa-bolt"></i> {videos.length} videos · {elapsed}s · {totalPages} págs.</span>
        )}
      </div>
    </header>

    <a href="/sheer" class="mb-6 inline-flex items-center gap-2 text-[0.95rem] text-muted transition-all duration-300 hover:-translate-x-1 hover:text-accent">
      <i class="fa-solid fa-arrow-left"></i> Volver al Catálogo
    </a>

    {/* Autenticación: pegar cookies o login con email/contraseña + validación. */}
    <SheerAuth />

    {/* Controles de scraping: recargan la página (SSR vuelve a scrapear). */}
    <form method="get" action="/sheer/live" class="mb-8 flex flex-wrap items-end gap-3 rounded-2xl border border-line bg-card px-4 py-4 sm:gap-4 sm:px-5">
      <div class="flex flex-col gap-1.5">
        <label for="alias" class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.5px] text-muted"><i class="fa-solid fa-user"></i> Creador</label>
        <input
          type="text"
          id="alias"
          name="alias"
          value={alias}
          class="w-full rounded-[10px] border border-line bg-[rgba(8,5,15,0.6)] px-3.5 py-2.5 text-[0.9rem] text-ink outline-none transition-all duration-300 hover:border-line-hover focus:border-line-hover sm:min-w-[180px]"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="paginas" class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.5px] text-muted"><i class="fa-solid fa-layer-group"></i> Páginas (1-40)</label>
        <input
          type="number"
          id="paginas"
          name="paginas"
          min="1"
          max="40"
          value={pages}
          class="w-full rounded-[10px] border border-line bg-[rgba(8,5,15,0.6)] px-3.5 py-2.5 text-[0.9rem] text-ink outline-none transition-all duration-300 hover:border-line-hover focus:border-line-hover sm:min-w-[140px]"
        />
      </div>
      <button type="submit" class="btn btn--primary !mt-0">
        <i class="fa-solid fa-rotate"></i> Scrapear en vivo
      </button>
      <p class="w-full text-[0.8rem] italic text-muted sm:w-auto sm:self-center">
        Cada página = ~10 videos. Más páginas = más tiempo. Los datos NO se guardan; solo se muestran.
      </p>
    </form>

    {error ? (
      <div class="px-8 py-16 text-center text-[1.2rem] text-danger">
        <i class="fa-solid fa-triangle-exclamation mb-4 block text-5xl"></i>
        <p>{error}</p>
      </div>
    ) : (
      <>
        {/* Search bar */}
        <div class="mb-6 flex gap-4 rounded-2xl border border-line bg-card px-4 py-3 shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all duration-300 focus-within:border-line-hover focus-within:shadow-glow sm:mb-10 sm:px-5">
          <span class="flex items-center text-[1.2rem] text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
          <input
            type="text"
            id="search"
            placeholder="Buscar videos por título, ID..."
            class="w-full border-none bg-transparent text-[1rem] text-ink outline-none placeholder:text-muted sm:text-[1.1rem]"
            autocomplete="off"
          />
        </div>

        {hasFilters && (
          <div class="mb-8 grid grid-cols-2 items-end gap-3 sm:-mt-4 sm:mb-10 sm:flex sm:flex-wrap sm:gap-4">
            {actresses.length > 0 && (
              <div class="flex flex-col gap-1.5">
                <label class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.5px] text-muted"><i class="fa-solid fa-user-tag"></i> Actriz</label>
                <select id="filter-actress" class="w-full cursor-pointer rounded-[10px] border border-line bg-card px-3.5 py-2.5 text-[0.9rem] text-ink outline-none transition-all duration-300 hover:border-line-hover focus:border-line-hover sm:min-w-[180px]">
                  <option value="">Todas ({actresses.length})</option>
                  {actresses.map((a) => (
                    <option value={a.name.toLowerCase()}>{a.name} ({a.count})</option>
                  ))}
                </select>
              </div>
            )}

            {categories.length > 0 && (
              <div class="flex flex-col gap-1.5">
                <label class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.5px] text-muted"><i class="fa-solid fa-tags"></i> Categoría</label>
                <select id="filter-category" class="w-full cursor-pointer rounded-[10px] border border-line bg-card px-3.5 py-2.5 text-[0.9rem] text-ink outline-none transition-all duration-300 hover:border-line-hover focus:border-line-hover sm:min-w-[180px]">
                  <option value="">Todas ({categories.length})</option>
                  {categories.map((c) => (
                    <option value={c.alias}>{c.name} ({c.count})</option>
                  ))}
                </select>
              </div>
            )}

            {resolutions.length > 0 && (
              <div class="flex flex-col gap-1.5">
                <label class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.5px] text-muted"><i class="fa-solid fa-clapperboard"></i> Calidad mín.</label>
                <select id="filter-resolution" class="w-full cursor-pointer rounded-[10px] border border-line bg-card px-3.5 py-2.5 text-[0.9rem] text-ink outline-none transition-all duration-300 hover:border-line-hover focus:border-line-hover sm:min-w-[180px]">
                  <option value="">Cualquiera</option>
                  {resolutions.map((r) => (
                    <option value={r}>{r}p+</option>
                  ))}
                </select>
              </div>
            )}

            <div class="flex flex-col gap-1.5">
              <label class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.5px] text-muted"><i class="fa-solid fa-arrow-down-wide-short"></i> Ordenar</label>
              <select id="filter-sort" class="w-full cursor-pointer rounded-[10px] border border-line bg-card px-3.5 py-2.5 text-[0.9rem] text-ink outline-none transition-all duration-300 hover:border-line-hover focus:border-line-hover sm:min-w-[180px]">
                <option value="default">Por defecto</option>
                <option value="date-desc">Fecha (recientes)</option>
                <option value="date-asc">Fecha (antiguos)</option>
                <option value="views-desc">Más vistos</option>
                <option value="views-asc">Menos vistos</option>
                <option value="title-asc">Título (A-Z)</option>
                <option value="title-desc">Título (Z-A)</option>
                <option value="res-desc">Calidad (mayor)</option>
                <option value="res-asc">Calidad (menor)</option>
              </select>
            </div>

            <button id="filter-clear" class="flex w-full cursor-pointer items-center justify-center gap-1.5 rounded-[10px] border border-line bg-[rgba(255,255,255,0.05)] px-4 py-2.5 text-[0.85rem] text-ink transition-all duration-300 hover:border-line-hover hover:bg-card-hover sm:w-auto sm:justify-start" type="button">
              <i class="fa-solid fa-xmark"></i> Limpiar
            </button>

            <div class="col-span-2 self-center text-right text-[0.85rem] font-semibold text-muted sm:col-span-1 sm:ml-auto" id="filter-count"></div>
          </div>
        )}

        {videos.length === 0 ? (
          <div class="px-8 py-16 text-center text-[1.2rem] text-muted">
            <i class="fa-solid fa-film mb-4 block text-5xl text-muted"></i>
            <p>No se obtuvieron videos del scrape en vivo.</p>
          </div>
        ) : (
          <>
            <div
              class="grid grid-cols-1 gap-5 sm:grid-cols-[repeat(auto-fill,minmax(310px,1fr))] sm:gap-8"
              id="video-grid"
              data-alias={alias}
              data-next-page={pages + 1}
              data-total-pages={totalPages}
            >
              {videos.map((video) => <SheerVideoCard video={video} />)}
            </div>

            <div id="no-results" class="hidden px-8 py-16 text-center text-[1.2rem] text-muted">
              <i class="fa-solid fa-ban mb-4 block text-5xl text-muted"></i>
              <p>No se encontraron videos que coincidan con la búsqueda.</p>
            </div>

            {/* Scroll infinito: sentinel + indicadores de carga / fin. */}
            <div id="scroll-sentinel" class="h-px w-full"></div>
            <div id="loading-more" class="hidden px-8 py-10 text-center text-[1rem] text-muted">
              <i class="fa-solid fa-spinner fa-spin mb-2 block text-3xl text-accent"></i>
              <p>Cargando más videos...</p>
            </div>
            <div id="end-of-list" class="hidden px-8 py-10 text-center text-[0.95rem] text-muted"></div>
          </>
        )}
      </>
    )}
  </div>
</Layout>

<script is:inline>
  const searchInput = document.getElementById('search');
  const grid = document.getElementById('video-grid');
  const noResults = document.getElementById('no-results');

  const actressSelect = document.getElementById('filter-actress');
  const categorySelect = document.getElementById('filter-category');
  const resolutionSelect = document.getElementById('filter-resolution');
  const sortSelect = document.getElementById('filter-sort');
  const clearBtn = document.getElementById('filter-clear');
  const filterCount = document.getElementById('filter-count');

  // `cards` crece con el scroll infinito, así que es mutable. `seen` deduplica
  // por postId; `orderCounter` mantiene el orden de llegada para "Por defecto".
  let cards = Array.from(document.querySelectorAll('.video-card'));
  const seen = new Set();
  let orderCounter = 0;
  cards.forEach((card) => {
    card.setAttribute('data-order', String(orderCounter++));
    const id = card.getAttribute('data-id');
    if (id) seen.add(id);
  });

  const applySort = () => {
    if (!grid) return;
    const mode = sortSelect?.value || 'default';
    const num = (el, attr) => parseInt(el.getAttribute(attr) || '0', 10) || 0;

    const sorted = [...cards].sort((a, b) => {
      const titleA = (a.getAttribute('data-title') || '').toLowerCase();
      const titleB = (b.getAttribute('data-title') || '').toLowerCase();
      const resA = num(a, 'data-res');
      const resB = num(b, 'data-res');
      const viewsA = num(a, 'data-views');
      const viewsB = num(b, 'data-views');
      const dateA = num(a, 'data-date');
      const dateB = num(b, 'data-date');
      const orderA = num(a, 'data-order');
      const orderB = num(b, 'data-order');

      switch (mode) {
        case 'title-asc': return titleA.localeCompare(titleB);
        case 'title-desc': return titleB.localeCompare(titleA);
        case 'res-desc': return resB - resA || titleA.localeCompare(titleB);
        case 'res-asc': return resA - resB || titleA.localeCompare(titleB);
        case 'views-desc': return viewsB - viewsA || titleA.localeCompare(titleB);
        case 'views-asc': return viewsA - viewsB || titleA.localeCompare(titleB);
        case 'date-desc': return dateB - dateA || titleA.localeCompare(titleB);
        case 'date-asc': return dateA - dateB || titleA.localeCompare(titleB);
        default: return orderA - orderB;
      }
    });

    sorted.forEach((card) => grid.appendChild(card));
  };

  const applyFilters = () => {
    const query = (searchInput?.value || '').toLowerCase().trim();
    const actress = (actressSelect?.value || '').toLowerCase();
    const category = (categorySelect?.value || '').toLowerCase();
    const minRes = parseInt(resolutionSelect?.value || '0', 10) || 0;

    let visibleCount = 0;

    cards.forEach((card) => {
      const blob = card.getAttribute('data-search') || card.getAttribute('data-title') || '';
      const id = (card.getAttribute('data-id') || '').toLowerCase();
      const models = (card.getAttribute('data-models') || '').split('|').filter(Boolean);
      const tags = (card.getAttribute('data-tags') || '').split('|').filter(Boolean);
      const res = parseInt(card.getAttribute('data-res') || '0', 10) || 0;

      const matchesSearch = !query || blob.includes(query) || id.includes(query);
      const matchesActress = !actress || models.includes(actress);
      const matchesCategory = !category || tags.includes(category);
      const matchesRes = !minRes || res >= minRes;

      if (matchesSearch && matchesActress && matchesCategory && matchesRes) {
        card.style.display = 'flex';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    if (filterCount) filterCount.textContent = `${visibleCount} de ${cards.length}`;

    if (visibleCount === 0) {
      if (noResults) noResults.classList.remove('hidden');
      if (grid) grid.style.display = 'none';
    } else {
      if (noResults) noResults.classList.add('hidden');
      if (grid) grid.style.display = 'grid';
    }
  };

  searchInput?.addEventListener('input', applyFilters);
  actressSelect?.addEventListener('change', applyFilters);
  categorySelect?.addEventListener('change', applyFilters);
  resolutionSelect?.addEventListener('change', applyFilters);
  sortSelect?.addEventListener('change', applySort);

  clearBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (actressSelect) actressSelect.value = '';
    if (categorySelect) categorySelect.value = '';
    if (resolutionSelect) resolutionSelect.value = '';
    if (sortSelect) sortSelect.value = 'default';
    applySort();
    applyFilters();
  });

  // Cablea los clics de categoría/actriz dentro de `container` (toda la página al
  // inicio, o solo las tarjetas nuevas tras un scroll). Marca los nodos ya
  // cableados con data-wired para no duplicar listeners.
  const wireCards = (container) => {
    container.querySelectorAll('.cat-tag[data-cat]:not([data-wired])').forEach((tag) => {
      tag.setAttribute('data-wired', '1');
      tag.addEventListener('click', (e) => {
        e.stopPropagation();
        if (!categorySelect) return;
        const cat = tag.getAttribute('data-cat') || '';
        categorySelect.value = cat;
        if (categorySelect.value !== cat) {
          const opt = Array.from(categorySelect.options).find((o) => o.value.toLowerCase() === cat.toLowerCase());
          if (opt) categorySelect.value = opt.value;
        }
        applyFilters();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });

    container.querySelectorAll('.actress-link[data-actress]:not([data-wired])').forEach((link) => {
      link.setAttribute('data-wired', '1');
      link.addEventListener('click', (e) => {
        e.stopPropagation();
        if (!actressSelect) return;
        const actress = link.getAttribute('data-actress') || '';
        actressSelect.value = actress;
        if (actressSelect.value !== actress) {
          const opt = Array.from(actressSelect.options).find((o) => o.value.toLowerCase() === actress.toLowerCase());
          if (opt) actressSelect.value = opt.value;
        }
        applyFilters();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  };

  // ── Scroll infinito ─────────────────────────────────────────────────────────
  const sentinel = document.getElementById('scroll-sentinel');
  const loadingEl = document.getElementById('loading-more');
  const endEl = document.getElementById('end-of-list');

  const gridAlias = grid?.dataset.alias || '';
  const totalPages = parseInt(grid?.dataset.totalPages || '1', 10) || 1;
  let nextPage = parseInt(grid?.dataset.nextPage || '2', 10) || 2;
  let hasMore = !!grid && nextPage <= totalPages;
  let loading = false;

  const finishList = () => {
    hasMore = false;
    loadingEl?.classList.add('hidden');
    if (endEl) {
      endEl.textContent = cards.length ? '— Fin del catálogo —' : 'Sin resultados.';
      endEl.classList.remove('hidden');
    }
    observer?.disconnect();
  };

  const loadMore = async () => {
    if (loading || !hasMore || !grid) return;
    loading = true;
    loadingEl?.classList.remove('hidden');

    try {
      const u = new URLSearchParams({ alias: gridAlias, page: String(nextPage) });
      const res = await fetch(`/sheer/live-cards?${u}`);
      const html = await res.text();
      const tmp = document.createElement('div');
      tmp.innerHTML = html;

      const newCards = [];
      tmp.querySelectorAll('.video-card').forEach((card) => {
        const id = card.getAttribute('data-id');
        if (id && seen.has(id)) return;
        if (id) seen.add(id);
        card.setAttribute('data-order', String(orderCounter++));
        grid.appendChild(card);
        cards.push(card);
        newCards.push(card);
      });

      newCards.forEach((c) => wireCards(c));
      applySort();
      applyFilters();

      nextPage++;
      hasMore = nextPage <= totalPages;
      loading = false;

      if (!hasMore) { finishList(); return; }
      loadingEl?.classList.add('hidden');
      // Si el sentinel sigue visible (pantallas altas), encadena otra carga.
      if (isSentinelVisible()) loadMore();
    } catch {
      loading = false;
      loadingEl?.classList.add('hidden');
    }
  };

  const isSentinelVisible = () => {
    if (!sentinel) return false;
    const r = sentinel.getBoundingClientRect();
    return r.top < window.innerHeight + 400;
  };

  const observer = new IntersectionObserver(
    (entries) => { if (entries.some((e) => e.isIntersecting)) loadMore(); },
    { rootMargin: '400px' },
  );

  // Init
  wireCards(document);
  applySort();
  applyFilters();
  if (hasMore && sentinel) observer.observe(sentinel);
  else if (!hasMore) finishList();
</script>
