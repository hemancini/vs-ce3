---
// Ruta parcial (sin layout): scrapea UNA página de Sheer y devuelve solo las
// tarjetas. La consume el scroll infinito de /sheer/live vía fetch(); el HTML
// resultante se inyecta en la grilla y se cablea con el mismo script.
//
// Parámetros (GET):
//   ?alias=<creador>   creador (default: TheGrey)
//   ?page=N            página de catálogo (default: 1)
import SheerVideoCard from '../../components/sheer/SheerVideoCard.astro';
import { scrapeSheerPage, DEFAULT_ALIAS } from '../../lib/sheer/scraper.js';

export const partial = true;
export const prerender = false;

const params = Astro.url.searchParams;
const alias = (params.get('alias') || DEFAULT_ALIAS).trim() || DEFAULT_ALIAS;
const page = Math.min(Math.max(parseInt(params.get('page') || '1', 10) || 1, 1), 40);

const env = (Astro.locals as any)?.runtime?.env;

let videos: any[] = [];
try {
  const result = await scrapeSheerPage({ alias, page, env });
  videos = result.videos;
} catch {
  videos = [];
}
---

{videos.map((video) => <SheerVideoCard video={video} />)}
