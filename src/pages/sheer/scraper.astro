---
import Layout from '../../layouts/Sheer.astro';
// El JSON generado por el scraper se empaqueta en build-time y actúa como API.
import videos from '../api/sheer/videos.json';

const existingVideosCount = Array.isArray(videos) ? videos.length : 0;
---

<Layout title="Consola del Scraper - Sheer">
  <div class="mx-auto max-w-[1300px] px-4 py-6 sm:px-6 sm:py-8">
    <header class="sticky top-0 z-[100] mb-8 flex flex-wrap items-center justify-between gap-3 border-b border-line bg-[rgba(8,5,15,0.8)] pb-4 backdrop-blur-md sm:mb-12 sm:pb-6">
      <a href="/sheer" class="text-gradient flex items-center gap-2 text-[1.35rem] font-extrabold tracking-[-0.5px] sm:text-[1.8rem]">
        <i class="fa-solid fa-play-circle"></i> Sheer Player
      </a>
      <div class="shrink-0 whitespace-nowrap rounded-full border border-line bg-card px-3 py-1.5 text-[0.8rem] text-muted sm:px-4 sm:py-2 sm:text-[0.9rem]">
        <i class="fa-solid fa-database"></i> {existingVideosCount} videos guardados
      </div>
    </header>

    <a href="/sheer" class="mb-6 inline-flex items-center gap-2 text-[0.95rem] text-muted transition-all duration-300 hover:-translate-x-1 hover:text-accent">
      <i class="fa-solid fa-arrow-left"></i> Volver al Catálogo
    </a>

    <div class="mt-6 grid grid-cols-1 gap-5 sm:gap-8 lg:grid-cols-2">
      <!-- Control Panel -->
      <div class="dashboard-card">
        <h2 class="flex items-center gap-3 border-b border-line pb-3 text-[1.25rem] font-bold text-ink [&>i]:text-accent"><i class="fa-solid fa-sliders"></i> Panel de Control</h2>

        <div class="flex flex-col gap-2">
          <label for="max-pages" class="text-[0.95rem] font-medium text-muted">Límite de páginas a raspar (deja vacío para raspar todo):</label>
          <div class="flex items-center rounded-xl border border-line px-4 transition-all duration-300 [background:rgba(8,5,15,0.6)] focus-within:border-line-hover focus-within:shadow-[0_0_10px_rgba(69,231,240,0.15)]">
            <input
              type="number"
              id="max-pages"
              min="1"
              placeholder="Ej. 2, 5, 10..."
              class="w-full border-none bg-transparent py-3.5 text-[1.1rem] text-ink outline-none [font-family:inherit]"
            />
            <span class="rounded-md bg-white/5 px-2 py-1 text-[0.75rem] font-bold uppercase text-muted">Páginas</span>
          </div>
          <p class="text-[0.8rem] italic text-muted">Por defecto, el scraper procesará todas las páginas disponibles (usualmente 40) si no se especifica un límite.</p>
        </div>

        <div class="mt-auto flex flex-col gap-3 sm:flex-row sm:gap-4">
          <button id="start-btn" class="btn btn--primary">
            <i class="fa-solid fa-play"></i> Iniciar Scraping
          </button>
          <button id="stop-btn" class="btn btn--danger" disabled>
            <i class="fa-solid fa-stop"></i> Detener
          </button>
        </div>
      </div>

      <!-- Live Progress & Metrics -->
      <div class="dashboard-card">
        <h2 class="flex items-center gap-3 border-b border-line pb-3 text-[1.25rem] font-bold text-ink [&>i]:text-accent"><i class="fa-solid fa-chart-line"></i> Progreso en Tiempo Real</h2>

        <div class="flex items-center gap-4 rounded-xl border border-line px-5 py-3 [background:rgba(8,5,15,0.4)]">
          <span class="text-[0.95rem] text-muted">Estado actual:</span>
          <span id="status-badge" class="status-badge status-badge--idle">Inactivo</span>
        </div>

        <!-- Progress Bar -->
        <div class="flex flex-col gap-2">
          <div class="flex justify-between text-[0.85rem] font-medium text-muted">
            <span id="progress-text">Páginas: 0 / 0</span>
            <span id="progress-percent">0%</span>
          </div>
          <div class="h-3 overflow-hidden rounded-[10px] border border-line [background:rgba(8,5,15,0.8)]">
            <div id="progress-bar-fill" class="progress-bar-fill"></div>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-3 gap-2 sm:gap-4">
          <div class="flex flex-col items-center gap-2 rounded-2xl border border-line p-3 text-center [background:rgba(8,5,15,0.5)] sm:flex-row sm:gap-3 sm:p-4 sm:text-left">
            <div class="flex items-center justify-center text-[1.5rem] text-muted"><i class="fa-solid fa-magnifying-glass"></i></div>
            <div class="flex flex-col">
              <span class="text-[1.25rem] font-extrabold text-ink" id="stat-current-page">-</span>
              <span class="text-[0.65rem] uppercase leading-tight tracking-[0.5px] text-muted sm:text-[0.75rem]">Página Actual</span>
            </div>
          </div>
          <div class="flex flex-col items-center gap-2 rounded-2xl border border-line p-3 text-center [background:rgba(8,5,15,0.5)] sm:flex-row sm:gap-3 sm:p-4 sm:text-left">
            <div class="flex items-center justify-center text-[1.5rem] text-muted"><i class="fa-solid fa-video"></i></div>
            <div class="flex flex-col">
              <span class="text-[1.25rem] font-extrabold text-ink" id="stat-videos-current">0</span>
              <span class="text-[0.65rem] uppercase leading-tight tracking-[0.5px] text-muted sm:text-[0.75rem]">Videos Encontrados</span>
            </div>
          </div>
          <div class="flex flex-col items-center gap-2 rounded-2xl border border-line p-3 text-center [background:rgba(8,5,15,0.5)] sm:flex-row sm:gap-3 sm:p-4 sm:text-left">
            <div class="flex items-center justify-center text-[1.5rem] text-muted"><i class="fa-solid fa-circle-check"></i></div>
            <div class="flex flex-col">
              <span class="text-[1.25rem] font-extrabold text-ink" id="stat-videos-total">0</span>
              <span class="text-[0.65rem] uppercase leading-tight tracking-[0.5px] text-muted sm:text-[0.75rem]">Total Extraídos</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Live Terminal Console -->
      <div class="dashboard-card !p-6 lg:col-span-2">
        <div class="flex flex-wrap items-center justify-between gap-3 border-b border-white/5 pb-3">
          <div class="flex items-center gap-2 font-mono text-[0.95rem] font-bold text-ink [&>i]:text-accent">
            <i class="fa-solid fa-terminal"></i> Terminal de Salida
          </div>
          <div class="flex gap-2">
            <button id="clear-console-btn" class="console-btn" title="Limpiar Consola">
              <i class="fa-solid fa-trash-can"></i>
            </button>
            <button id="autoscroll-btn" class="console-btn active" title="Autodesplazamiento activo">
              <i class="fa-solid fa-down-to-line"></i> Auto-scroll
            </button>
          </div>
        </div>
        <div id="terminal" class="terminal-body">
          <div class="terminal-line terminal-line--system">Consola lista. Haz clic en "Iniciar Scraping" para comenzar...</div>
        </div>
      </div>
    </div>
  </div>
</Layout>
<script is:inline>
  let eventSource = null;
  let totalVideosFoundInSession = 0;

  const startBtn = document.getElementById('start-btn');
  const stopBtn = document.getElementById('stop-btn');
  const maxPagesInput = document.getElementById('max-pages');
  
  const statusBadge = document.getElementById('status-badge');
  const progressBar = document.getElementById('progress-bar-fill');
  const progressText = document.getElementById('progress-text');
  const progressPercent = document.getElementById('progress-percent');
  
  const statCurrentPage = document.getElementById('stat-current-page');
  const statVideosCurrent = document.getElementById('stat-videos-current');
  const statVideosTotal = document.getElementById('stat-videos-total');
  
  const terminal = document.getElementById('terminal');
  const clearConsoleBtn = document.getElementById('clear-console-btn');
  const autoscrollBtn = document.getElementById('autoscroll-btn');

  let autoscroll = true;

  // Toggle autoscroll
  autoscrollBtn.addEventListener('click', () => {
    autoscroll = !autoscroll;
    autoscrollBtn.classList.toggle('active', autoscroll);
  });

  // Clear console
  clearConsoleBtn.addEventListener('click', () => {
    terminal.innerHTML = '';
    appendLog('Consola limpiada.', 'system');
  });

  // Helper to append lines to the terminal
  function appendLog(text, type = 'normal') {
    const line = document.createElement('div');
    line.className = 'terminal-line';
    
    // Auto-detect styles based on text contents if not explicit
    if (type === 'normal') {
      if (text.includes('[ERROR]') || text.toLowerCase().includes('error:')) {
        line.classList.add('terminal-line--error');
      } else if (text.toLowerCase().includes('complete') || text.includes('Successfully')) {
        line.classList.add('terminal-line--success');
      } else if (text.includes('[Page') && text.includes('Loading')) {
        line.classList.add('terminal-line--highlight');
      } else if (text.includes('Video: "')) {
        line.classList.add('terminal-line--video');
      } else if (text.includes('Warning') || text.includes('Warning:')) {
        line.classList.add('terminal-line--warning');
      }
    } else {
      line.classList.add(`terminal-line--${type}`);
    }

    line.textContent = text;
    terminal.appendChild(line);

    if (autoscroll) {
      terminal.scrollTop = terminal.scrollHeight;
    }
  }

  // Update overall page status UI
  function setStatus(status) {
    statusBadge.className = 'status-badge';
    
    if (status === 'idle') {
      statusBadge.textContent = 'Inactivo';
      statusBadge.classList.add('status-badge--idle');
      startBtn.disabled = false;
      stopBtn.disabled = true;
      maxPagesInput.disabled = false;
    } else if (status === 'running') {
      statusBadge.textContent = 'Ejecutando';
      statusBadge.classList.add('status-badge--running');
      startBtn.disabled = true;
      stopBtn.disabled = false;
      maxPagesInput.disabled = true;
    } else if (status === 'success') {
      statusBadge.textContent = 'Completado';
      statusBadge.classList.add('status-badge--success');
      startBtn.disabled = false;
      stopBtn.disabled = true;
      maxPagesInput.disabled = false;
    } else if (status === 'error') {
      statusBadge.textContent = 'Error';
      statusBadge.classList.add('status-badge--error');
      startBtn.disabled = false;
      stopBtn.disabled = true;
      maxPagesInput.disabled = false;
    }
  }

  // Stop / Cancel handler
  function stopScraping() {
    if (eventSource) {
      eventSource.close();
      eventSource = null;
      appendLog('Proceso de scraping abortado por el usuario.', 'warning');
      setStatus('idle');
    }
  }

  stopBtn.addEventListener('click', stopScraping);

  // Start scraper handler
  startBtn.addEventListener('click', () => {
    const maxPages = maxPagesInput.value.trim();
    
    // Reset stats
    totalVideosFoundInSession = 0;
    statCurrentPage.textContent = '-';
    statVideosCurrent.textContent = '0';
    statVideosTotal.textContent = '0';
    progressBar.style.width = '0%';
    progressPercent.textContent = '0%';
    progressText.textContent = 'Páginas: 0 / 0';
    
    terminal.innerHTML = '';
    appendLog('Iniciando proceso de scraping en segundo plano...', 'system');
    setStatus('running');

    // Build URL query params
    let url = '/api/sheer/scrape';
    if (maxPages) {
      url += `?maxPages=${maxPages}`;
    }

    // Connect to SSE API
    eventSource = new EventSource(url);

    eventSource.addEventListener('status', (e) => {
      const data = JSON.parse(e.data);
      appendLog(`[Sistema] ${data.message}`, 'system');
      
      if (data.status === 'started') {
        setStatus('running');
      } else if (data.status === 'finished') {
        setStatus(data.code === 0 ? 'success' : 'error');
        eventSource.close();
        eventSource = null;
      } else if (data.status === 'error') {
        setStatus('error');
        eventSource.close();
        eventSource = null;
      }
    });

    eventSource.addEventListener('log', (e) => {
      const data = JSON.parse(e.data);
      appendLog(data.message, data.isError ? 'error' : 'normal');
    });

    eventSource.addEventListener('progress', (e) => {
      const data = JSON.parse(e.data);
      const current = data.current;
      const total = data.total;
      const percent = total > 0 ? Math.round((current / total) * 100) : 0;

      progressBar.style.width = `${percent}%`;
      progressPercent.textContent = `${percent}%`;
      progressText.textContent = `Páginas: ${current} / ${total}`;
      
      statCurrentPage.textContent = `${current} / ${total}`;
    });

    eventSource.addEventListener('videos_found', (e) => {
      const data = JSON.parse(e.data);
      statVideosCurrent.textContent = data.count;
    });

    eventSource.addEventListener('complete', (e) => {
      const data = JSON.parse(e.data);
      totalVideosFoundInSession = data.total;
      statVideosTotal.textContent = data.total;
      appendLog(`[Resumen] Scraping finalizado. Se recopilaron un total de ${data.total} videos.`, 'success');
    });

    eventSource.onerror = (err) => {
      console.error('EventSource error:', err);
      // SSE connection can be closed cleanly or fail
      if (eventSource.readyState === EventSource.CLOSED) {
        // Handled via status closed
      } else {
        appendLog('Error de conexión con la consola del scraper.', 'error');
        setStatus('error');
        eventSource.close();
        eventSource = null;
      }
    };
  });
</script>
