---
import Layout from '@/layouts/Layout.astro';
export const prerender = false;
---
<Layout title="vs">
  <h1 class="text-2xl font-bold text-white mb-6">vs</h1>

  <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3 mt-7">Vistas</h2>
  <ul class="flex flex-col gap-2 list-none p-0" aria-label="Páginas disponibles">
    <li>
      <a
        href="/vodscene/videos"
        class="flex items-center gap-3 bg-vs-surface border border-vs-border rounded-lg px-5 py-3.5 hover:border-blue-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 transition-colors no-underline"
        aria-label="Ver todos los videos"
      >
        <span class="text-xl" aria-hidden="true">▶</span>
        <div class="min-w-0">
          <div class="text-white font-semibold text-[.95rem]">Videos</div>
          <div class="text-gray-500 text-xs">
            Galería de la colección <code class="bg-gray-800 px-1.5 py-px rounded text-[.875em]">videos</code>
          </div>
        </div>
      </a>
    </li>
    <li>
      <a
        href="/vodscene/participants"
        class="flex items-center gap-3 bg-vs-surface border border-vs-border rounded-lg px-5 py-3.5 hover:border-blue-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 transition-colors no-underline"
        aria-label="Ver todos los participantes"
      >
        <span class="text-xl" aria-hidden="true">👥</span>
        <div class="min-w-0">
          <div class="text-white font-semibold text-[.95rem]">Participantes</div>
          <div class="text-gray-500 text-xs">
            Tabla de la colección <code class="bg-gray-800 px-1.5 py-px rounded text-[.875em]">participants</code>
          </div>
        </div>
      </a>
    </li>
  </ul>

  <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3 mt-7">BuyMyVids</h2>
  <ul class="flex flex-col gap-2 list-none p-0" aria-label="Páginas BuyMyVids">
    <li>
      <a
        href="/buymyvids/videos"
        class="flex items-center gap-3 bg-vs-surface border border-vs-border rounded-lg px-5 py-3.5 hover:border-blue-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 transition-colors no-underline"
        aria-label="Ver videos de BuyMyVids"
      >
        <span class="text-xl" aria-hidden="true">🎬</span>
        <div class="min-w-0">
          <div class="text-white font-semibold text-[.95rem]">Videos</div>
          <div class="text-gray-500 text-xs">Galería de videos de BuyMyVids</div>
        </div>
      </a>
    </li>
  </ul>

  <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3 mt-7">API Endpoints</h2>
  <ul class="flex flex-col gap-2 list-none p-0" aria-label="Endpoints de la API">
    <li class="flex gap-2 items-baseline text-sm text-gray-400">
      <code class="bg-gray-800 px-1.5 py-px rounded text-[.875em] text-gray-300">GET</code>
      <a href="/api/vodscene/firestore" class="text-blue-400 hover:text-blue-300 hover:underline">/api/firestore</a>
      — dump completo de todas las colecciones accesibles
    </li>
    <li class="flex gap-2 items-baseline text-sm text-gray-400">
      <code class="bg-gray-800 px-1.5 py-px rounded text-[.875em] text-gray-300">GET</code>
      <a href="/api/vodscene/firestore?collection=videos" class="text-blue-400 hover:text-blue-300 hover:underline">/api/firestore?collection=videos</a>
      — solo la colección <code class="bg-gray-800 px-1.5 py-px rounded text-[.875em] text-gray-300">videos</code>
    </li>
    <li class="flex gap-2 items-baseline text-sm text-gray-400">
      <code class="bg-gray-800 px-1.5 py-px rounded text-[.875em] text-gray-300">GET</code>
      <a href="/api/vodscene/firestore?collection=participants" class="text-blue-400 hover:text-blue-300 hover:underline">/api/firestore?collection=participants</a>
      — solo la colección <code class="bg-gray-800 px-1.5 py-px rounded text-[.875em] text-gray-300">participants</code>
    </li>
  </ul>
</Layout>

