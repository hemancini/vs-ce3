---
import Layout from "@/layouts/Layout.astro";
export const prerender = false;
---

<Layout title="vs">
  <div class="flex flex-col w-full max-w-7xl mx-auto">
    <ul
      class="flex flex-col gap-4 list-none p-0"
      aria-label="Páginas disponibles"
    >
      <li>
        <a
          href="/vodscene/"
          class="focusable flex items-center gap-3 bg-vs-surface border border-vs-border rounded-lg px-5 py-3.5 hover:border-blue-400 focus-visible:outline-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400 transition-colors no-underline"
          aria-label="Ver todos los videos"
        >
          <span class="text-xl" aria-hidden="true">▶</span>
          <div class="min-w-0">
            <div class="text-white font-semibold text-[.95rem]">Vodscene</div>
            <div class="text-gray-500 text-xs">
              Galería de la colección <code
                class="bg-gray-800 px-1.5 py-px rounded text-[.875em]"
                >videos</code
              >
            </div>
          </div>
        </a>
      </li>
      <li>
        <a
          href="/buymyvids"
          class="focusable flex items-center gap-3 bg-vs-surface border border-vs-border rounded-lg px-5 py-3.5 hover:border-blue-400 focus-visible:outline-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400 transition-colors no-underline"
          aria-label="Ver videos de BuyMyVids"
        >
          <span class="text-xl" aria-hidden="true">🎬</span>
          <div class="min-w-0">
            <div class="text-white font-semibold text-[.95rem]">BuyMyVids</div>
            <div class="text-gray-500 text-xs">
              Galería de videos de BuyMyVids
            </div>
          </div>
        </a>
      </li>
      <li>
        <div class="flex items-center gap-3 bg-vs-surface border border-vs-border rounded-lg px-5 py-3.5 opacity-60">
          <span class="text-xl" aria-hidden="true">🚧</span>
          <div class="min-w-0">
            <div class="text-white font-semibold text-[.95rem]">Arsmate</div>
            <div class="text-gray-500 text-xs">Próximamente</div>
          </div>
        </div>
      </li>
    </ul>
  </div>
</Layout>
