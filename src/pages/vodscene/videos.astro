      <button id="tab-btn-raw"     class="focusable text-sm font-medium px-1 py-3 border-b-2 border-transparent text-gray-500 hover:text-gray-300 cursor-pointer bg-transparent transition-colors" aria-selected="false" tabindex="0">Raw JSON</button>
