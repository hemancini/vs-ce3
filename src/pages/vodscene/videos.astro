---
import Layout from '@/layouts/Layout.astro';
export const prerender = false;

// ─── Tipos ────────────────────────────────────────────────────────────────────
interface DrmConfig {
  enabled?: boolean;
  savedAt?: string;
  keyId?: string;
  widevine?: { licenseUrl: string; pssh?: string };
  playready?: { licenseUrl?: string; laUrl: string };
}
interface FairPlayConfig {
  enabled?: boolean;
  licenseUrl?: string;
  keyUri?: string;
  kid?: string;
  assetId?: string;
  ivHex?: string;
}
interface PublicUrls {
  dashManifest?: string;
  dashManifestNoDRM?: string;
  hlsFairPlayManifest?: string;
  trailerManifest?: string;
  coverImage?: string;
  fullPoster?: string;
  hoverFullPoster?: string;
  thumbnailFull?: string;
  thumbnailTrailer?: string;
  trailerPoster?: string;
  fullGif?: string;
  trailerGif?: string;
}
interface VideoDoc {
  id: string;
  title?: string;
  description?: string;
  processingStatus?: string;
  isActive?: boolean;
  hasNoDRMVersion?: boolean;
  permitirPlaySinDRM?: boolean;
  views?: number | string;
  likes?: number | string;
  cost?: number | string;
  createdAt?: string;
  drm?: DrmConfig;
  fairplay?: FairPlayConfig;
  publicUrls?: PublicUrls;
  [key: string]: unknown;
}

interface PlaylistDoc {
  id: string;
  title?: string;
  name?: string;
  description?: string;
  order?: number | string;
  createdAt?: string;
  [key: string]: unknown;
}

interface ApiResponse {
  meta: {
    totalCollections: number;
    totalDocuments: number;
    collections: Record<string, { count: number; accessible: boolean; error?: string }>;
  };
  data: Record<string, Record<string, Record<string, unknown>>>;
}

// ─── Fetch server-side ────────────────────────────────────────────────────────
let videos: VideoDoc[] = [];
let playlists: PlaylistDoc[] = [];
let error: string | null = null;
let totalCount = 0;

try {
  const origin = Astro.url.origin;
  const cookie = Astro.request.headers.get('cookie') ?? '';
  const res = await fetch(`${origin}/api/vodscene/firestore?collections=videos,playlists`, {
    headers: { cookie },
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const json: ApiResponse = await res.json();

  const colMeta = json.meta?.collections?.videos;
  if (!colMeta?.accessible) {
    error = colMeta?.error ?? "Colección no accesible";
  } else {
    const raw = json.data?.videos ?? {};
    totalCount = colMeta.count;
    videos = Object.entries(raw).map(([id, fields]) => ({ id, ...fields } as VideoDoc));
    videos.sort((a, b) => {
      const da = a.createdAt ? new Date(a.createdAt).getTime() : 0;
      const db = b.createdAt ? new Date(b.createdAt).getTime() : 0;
      return db - da;
    });
  }

  // Playlists (best-effort: no error si no es accesible)
  const plMeta = json.meta?.collections?.playlists;
  if (plMeta?.accessible) {
    const rawPl = json.data?.playlists ?? {};
    playlists = Object.entries(rawPl).map(([id, fields]) => ({ id, ...fields } as PlaylistDoc));
    playlists.sort((a, b) => {
      const oa = Number(a.order ?? 9999), ob = Number(b.order ?? 9999);
      if (oa !== ob) return oa - ob;
      return (a.title ?? a.name ?? "").localeCompare(b.title ?? b.name ?? "", "es");
    });
  }
} catch (e) {
  error = e instanceof Error ? e.message : "Error desconocido";
}

// ─── Agrupar videos por playlist ──────────────────────────────────────────────
const playlistMap = new Map<string, PlaylistDoc>(playlists.map((p) => [p.id, p]));

interface VideoGroup {
  playlist: PlaylistDoc | null;
  videos: VideoDoc[];
}

// Construir grupos respetando el orden de playlists
const groupMap = new Map<string, VideoGroup>();
for (const pl of playlists) {
  groupMap.set(pl.id, { playlist: pl, videos: [] });
}
// Grupo especial para videos sin playlistId
const noGroup: VideoGroup = { playlist: null, videos: [] };

for (const v of videos) {
  const pid = v.playlistId as string | undefined;
  if (pid && groupMap.has(pid)) {
    groupMap.get(pid)!.videos.push(v);
  } else {
    noGroup.videos.push(v);
  }
}

// Grupos con al menos un video + sin categoría al final
const groups: VideoGroup[] = [...groupMap.values()].filter((g) => g.videos.length > 0);
if (noGroup.videos.length > 0) groups.push(noGroup);

// ─── Helpers ──────────────────────────────────────────────────────────────────
function formatDate(val: unknown): string {
  if (!val) return "—";
  const d = new Date(val as string);
  return isNaN(d.getTime()) ? String(val)
    : new Intl.DateTimeFormat("es", { dateStyle: "medium" }).format(d);
}
function formatViews(val: unknown): string {
  if (val === undefined || val === null) return "—";
  const n = Number(val);
  return isNaN(n) ? String(val) : new Intl.NumberFormat("es").format(n);
}
function formatCost(val: unknown): string {
  if (val === undefined || val === null) return "";
  const n = Number(val);
  if (isNaN(n) || n === 0) return "Gratis";
  return new Intl.NumberFormat("es-AR", { style: "currency", currency: "ARS", maximumFractionDigits: 0 }).format(n);
}
function getThumb(v: VideoDoc): string | null {
  return v.publicUrls?.coverImage ?? v.publicUrls?.thumbnailFull
    ?? v.publicUrls?.fullPoster ?? v.publicUrls?.trailerPoster ?? null;
}

type PlayMode = "nodrm" | "widevine" | "trailer" | "unavailable";
function getPlayMode(v: VideoDoc): PlayMode {
  if (v.processingStatus !== "ready") return "unavailable";
  if (v.permitirPlaySinDRM || v.hasNoDRMVersion) return "nodrm";
  if (v.drm?.enabled && v.publicUrls?.dashManifest) return "widevine";
  if (v.publicUrls?.trailerManifest) return "trailer";
  return "unavailable";
}

interface VideoPlayerData {
  id: string;
  title: string;
  mode: PlayMode;
  dashNoDRM?: string;
  dashDRM?: string;
  hlsFP?: string;
  trailer?: string;
  poster?: string;
  widevineUrl?: string;
  playreadyUrl?: string;
  fpLicenseUrl?: string;
  uploadedBy?: string;
}
function buildPlayerData(v: VideoDoc): VideoPlayerData {
  return {
    id:           v.id,
    title:        String(v.title ?? "Sin título"),
    mode:         getPlayMode(v),
    dashNoDRM:    v.publicUrls?.dashManifestNoDRM,
    dashDRM:      v.publicUrls?.dashManifest,
    hlsFP:        v.publicUrls?.hlsFairPlayManifest,
    trailer:      v.publicUrls?.trailerManifest,
    poster:       getThumb(v) ?? undefined,
    widevineUrl:  v.drm?.widevine?.licenseUrl,
    playreadyUrl: v.drm?.playready?.laUrl ?? v.drm?.playready?.licenseUrl,
    fpLicenseUrl: v.fairplay?.licenseUrl,
    uploadedBy:   v.uploadedBy as string | undefined,
  };
}

const KNOWN = new Set([
  "title","description","publicUrls","drm","fairplay","hasNoDRMVersion",
  "permitirPlaySinDRM","views","likes","cost","createdAt","updatedAt",
  "processingStatus","isActive","participants","uploadedBy","uploaderId",
  "playlistId","commentsCount","subscriptionViews","userLikes","r2Paths",
  "coconutJobStatus","processingProgress","hasManualThumbnail","lastUpdated","id"
]);

const playerDataMap: Record<string, VideoPlayerData> = {};
for (const v of videos) playerDataMap[v.id] = buildPlayerData(v);
const playerDataJson = JSON.stringify(playerDataMap);

// Datos de playlists para el cliente
const playlistsJson = JSON.stringify(
  Object.fromEntries(playlists.map((p) => [p.id, { title: p.title ?? p.name ?? p.id }]))
);

// Clases Tailwind definidas completas para que el compilador las detecte
const modeBadgeClasses: Record<string, string> = {
  nodrm:       "bg-[#052e16] text-green-400 border border-[#166534]",
  widevine:    "bg-[#0d1a2e] text-blue-300 border border-[#1e40af]",
  trailer:     "bg-[#1c1007] text-amber-400 border border-[#92400e]",
  unavailable: "bg-vs-surface text-gray-500 border border-vs-border",
};
const modeBadgeLabels: Record<string, string> = {
  nodrm: "Sin DRM", widevine: "Widevine", trailer: "Tráiler", unavailable: "No disponible",
};

// ─── Extraer Hashtags ────────────────────────────────────────────────────────
const hashtagCounts: Record<string, number> = {};
videos.forEach(v => {
  if (Array.isArray(v.hashtags)) {
    v.hashtags.forEach(tag => {
      hashtagCounts[tag] = (hashtagCounts[tag] || 0) + 1;
    });
  }
});
const sortedHashtags = Object.entries(hashtagCounts).sort((a, b) => b[1] - a[1]);
const hashtagsJson = JSON.stringify(sortedHashtags);
---

<Layout title="Videos — vodscene">
  <Fragment slot="head">
    <!-- Shaka Player UI (DASH + Widevine + PlayReady + FairPlay) -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/shaka-player/4.3.5/shaka-player.ui.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/shaka-player/4.3.5/controls.min.css" />
  </Fragment>

  <header class="mb-8">
    <nav class="mb-3" aria-label="Navegación principal">
      <a href="/" class="focusable text-blue-400 hover:text-blue-300 hover:underline text-sm">← Inicio</a>
    </nav>
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-3xl font-bold text-white">Videos</h1>
        {!error && (
          <p class="text-gray-500 text-sm mt-1 tabular-nums" id="video-count">
            {totalCount === 0 ? "Sin videos"
              : `${new Intl.NumberFormat("es").format(totalCount)} ${totalCount === 1 ? "video" : "videos"}`}
          </p>
        )}
      </div>
      {videos.length > 0 && (
        <div class="flex gap-2 flex-wrap items-center">
          <div class="relative flex-1 min-w-[180px] sm:w-72">
            <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input
              id="video-search"
              type="search"
              placeholder="Buscar por título, descripción o ID…"
              autocomplete="off"
              class="focusable w-full bg-vs-surface border border-vs-border rounded-[6px] pl-8 pr-3 py-1.5 text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:border-blue-400 transition-colors"
              aria-label="Buscar videos"
            />
          </div>
          <select
            id="video-sort"
            aria-label="Ordenar videos"
            class="focusable bg-vs-surface border border-vs-border rounded-[6px] px-2 py-1.5 text-sm text-gray-300 focus:outline-none focus:border-blue-400 transition-colors cursor-pointer"
          >
            <option value="date-desc">Más reciente</option>
            <option value="date-asc">Más antiguo</option>
            <option value="title-asc">Título A → Z</option>
            <option value="title-desc">Título Z → A</option>
            <option value="views-desc">Más vistas</option>
            <option value="views-asc">Menos vistas</option>
            <option value="likes-desc">Más me gustas</option>
            <option value="likes-asc">Menos me gustas</option>
            <option value="cost-desc">Mayor precio</option>
            <option value="cost-asc">Menor precio</option>
          </select>
          {/* Toggle vista */}
          <div class="flex rounded-[6px] border border-vs-border overflow-hidden flex-shrink-0" role="group" aria-label="Modo de vista">
            <button
              id="view-btn-grouped"
              class="focusable flex items-center gap-1.5 px-2.5 py-1.5 text-sm font-medium bg-blue-500/20 text-blue-300 border-r border-vs-border cursor-pointer transition-colors"
              aria-pressed="true"
              title="Agrupar por categoría"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="4" rx="1"/><rect x="3" y="10" width="7" height="4" rx="1"/><rect x="3" y="17" width="7" height="4" rx="1"/><rect x="14" y="3" width="7" height="4" rx="1"/><rect x="14" y="10" width="7" height="4" rx="1"/></svg>
              Categorías
            </button>
            <button
              id="view-btn-list"
              class="focusable flex items-center gap-1.5 px-2.5 py-1.5 text-sm font-medium bg-transparent text-gray-400 hover:text-gray-200 cursor-pointer transition-colors border-r border-vs-border"
              aria-pressed="false"
              title="Lista plana"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg>
              Lista
            </button>
            <button
              id="view-btn-poster"
              class="focusable flex items-center gap-1.5 px-2.5 py-1.5 text-sm font-medium bg-transparent text-gray-400 hover:text-gray-200 cursor-pointer transition-colors border-r border-vs-border"
              aria-pressed="false"
              title="Vista poster horizontal"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M4 8h16"/></svg>
              Poster
            </button>
            <button
              id="view-btn-hashtags"
              class="focusable flex items-center gap-1.5 px-2.5 py-1.5 text-sm font-medium bg-transparent text-gray-400 hover:text-gray-200 cursor-pointer transition-colors"
              aria-pressed="false"
              title="Vista por hashtags"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 9h16M4 15h16M10 3L8 21M16 3l-2 18"/></svg>
              Hashtags
            </button>
          </div>
        </div>
      )}
    </div>
  </header>

  <main id="main-content">
    {/* Barra de filtros por hashtag (visible solo en modo hashtags) */}
    <div id="hashtags-filter-bar" class="hidden mb-6 overflow-x-auto pb-2 scrollbar-hide">
      <div class="flex flex-wrap gap-2">
        <button
          class="hashtag-chip focusable px-3 py-1.5 rounded-full bg-blue-500 text-white text-xs font-semibold border border-blue-400 transition-colors cursor-pointer"
          data-tag="all"
        >
          Todos
        </button>
        {sortedHashtags.map(([tag, count]) => (
          <button
            class="hashtag-chip focusable px-3 py-1.5 rounded-full bg-vs-surface border border-vs-border text-gray-400 text-xs font-semibold hover:border-blue-400 hover:text-blue-400 transition-colors cursor-pointer"
            data-tag={tag}
          >
            #{tag} <span class="text-gray-600 ml-1 text-[10px]">{count}</span>
          </button>
        ))}
      </div>
    </div>
    {error && (
      <div class="bg-red-950 border border-red-900 rounded-lg px-5 py-4 text-red-400 mb-6" role="alert" aria-live="polite">
        <strong>Error al cargar los videos:</strong> {error}
      </div>
    )}

    {!error && videos.length === 0 && (
      <div class="text-center py-16 text-gray-500" role="status"><p>No se encontraron videos.</p></div>
    )}

    <div id="search-empty" class="text-center py-16 text-gray-500 hidden" role="status">No hay videos que coincidan con la búsqueda.</div>

    {videos.length > 0 && (
      <div id="sections-container" class="view-grouped">
        {groups.map((group) => {
          const sectionId = group.playlist?.id ?? "__none__";
          const sectionTitle = group.playlist
            ? (group.playlist.title ?? group.playlist.name ?? group.playlist.id)
            : "Sin categoría";
          return (
            <section data-section-id={sectionId}>
              {/* Encabezado de sección (visible solo en modo agrupado) */}
              <div class="section-heading flex items-center gap-3 mb-4">
                <button
                  class="focusable section-toggle flex items-center gap-2 text-base font-semibold text-gray-200 hover:text-white bg-transparent border-0 p-0 cursor-pointer transition-colors group"
                  aria-expanded="true"
                  aria-controls={`grid-${sectionId}`}
                  data-section-toggle={sectionId}
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400 flex-shrink-0" aria-hidden="true"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2z"/></svg>
                  {sectionTitle}
                  <svg class="section-chevron text-gray-500 flex-shrink-0 transition-transform duration-200" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <span class="text-[.7rem] font-semibold px-1.5 py-[2px] rounded bg-vs-surface border border-vs-border text-gray-500 tabular-nums flex-shrink-0 section-count" data-total={group.videos.length}>
                  {group.videos.length} {group.videos.length === 1 ? "video" : "videos"}
                </span>
                <div class="flex-1 h-px bg-vs-border"></div>
              </div>
              <ol id={`grid-${sectionId}`} class="section-grid grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-5 list-none p-0 mb-10" aria-label={`Videos: ${sectionTitle}`}>
                {group.videos.map((v) => {
                  const extraKeys = Object.keys(v).filter((k) => !KNOWN.has(k));
                  const thumb   = getThumb(v);
                  const gifUrl  = v.publicUrls?.fullGif ?? v.publicUrls?.trailerGif ?? null;
                  const mode    = getPlayMode(v);
                  const canPlay = mode !== "unavailable";
                  const badgeCls   = modeBadgeClasses[mode];
                  const badgeLabel = modeBadgeLabels[mode];
                  const searchText = [v.title, v.description, v.id, sectionTitle].filter(Boolean).join(" ").toLowerCase();
                  return (
                    <li
                      data-search={searchText}
                      data-title={(v.title ?? "").toLowerCase()}
                      data-views={String(Number(v.views ?? 0))}
                      data-likes={String(Number(v.likes ?? 0))}
                      data-cost={String(Number(v.cost ?? 0))}
                      data-created={String(v.createdAt ? new Date(v.createdAt).getTime() : 0)}
                      data-playlist-id={sectionId}
                      data-poster-img={v.publicUrls?.coverImage ?? v.publicUrls?.fullPoster ?? "/cover.jpg"}
                      data-trailer-gif={v.publicUrls?.trailerGif ?? "/trailer-preview.gif"}
                      data-hashtags={JSON.stringify(v.hashtags || [])}
                    >
                      <article class="bg-vs-surface border border-vs-border rounded-lg overflow-hidden flex flex-col hover:border-blue-400 motion-safe:hover:-translate-y-0.5 transition-[border-color,transform] touch-manipulation" aria-labelledby={`title-${v.id}`}>

                        {/* Miniatura + overlay play */}
                        <div class="poster-thumb-wrap aspect-video bg-[#111] overflow-hidden relative" data-gif={gifUrl ?? ""} data-thumb={thumb ?? ""}>
                          {thumb
                            ? <img src={thumb} alt="" width="560" height="315" loading="lazy" aria-hidden="true" class="w-full h-full object-cover block transition-opacity duration-200" data-original-src={thumb} />
                            : <div class="w-full h-full flex items-center justify-center text-gray-500 text-[2rem] select-none" aria-hidden="true">▶</div>
                          }
                          <span class={`absolute top-1.5 right-1.5 text-[.65rem] font-bold tracking-[.04em] px-1.5 py-[2px] rounded-[3px] pointer-events-none ${badgeCls}`} aria-hidden="true">
                            {badgeLabel}
                          </span>
                          {canPlay && (
                            <div class="group absolute inset-0 flex items-center justify-center hover:bg-black/45 transition-colors">
                              <button
                                class="focusable absolute inset-0 bg-transparent border-0 cursor-pointer focus-visible:outline-[3px] focus-visible:outline-blue-400 focus-visible:outline-offset-[-3px]"
                                aria-label={`Reproducir: ${v.title ?? v.id}`}
                                data-video-id={v.id}
                              >
                                <span class="w-[52px] h-[52px] rounded-full bg-black/65 border-2 border-white/80 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" aria-hidden="true">
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="fill-white w-[22px] h-[22px] translate-x-[2px]"><polygon points="5,3 19,12 5,21"/></svg>
                                </span>
                              </button>
                              <button
                                class="focusable absolute bottom-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity z-10 inline-flex items-center gap-1 text-[.68rem] font-semibold px-2 py-1 rounded bg-black/70 border border-white/20 text-white/80 hover:border-blue-400 hover:text-blue-400 cursor-pointer"
                                data-popup-id={v.id}
                                data-popup-trailer={mode === "trailer" ? "1" : "0"}
                                aria-label={`Abrir popup: ${v.title ?? v.id}`}
                                title="Abrir en ventana flotante"
                              >
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M3 9h6"/></svg>
                                Popup
                              </button>
                            </div>
                          )}
                          {/* Overlays exclusivos de vista Poster */}
                          {v.cost !== undefined && Number(v.cost) > 0 && (
                            <span class="poster-badge">
                              {new Intl.NumberFormat("es-CL", { style: "currency", currency: "CLP", maximumFractionDigits: 0 }).format(Number(v.cost))}
                            </span>
                          )}
                          <div class="poster-play" aria-hidden="true">
                            {canPlay && (
                              <button
                                class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/90 text-black cursor-pointer border-0"
                                data-video-id={v.id}
                                tabindex="-1"
                                aria-hidden="true"
                              >
                                <svg viewBox="0 0 24 24" class="fill-current w-4 h-4 translate-x-[1px]"><polygon points="5,3 19,12 5,21"/></svg>
                              </button>
                            )}
                          </div>
                          <div class="poster-title">{v.title ?? "Sin título"}</div>
                        </div>

                        {/* Cuerpo */}
                        <div class="px-4 py-3.5 flex flex-col gap-1.5 flex-1">
                          <h3 class="font-semibold text-[.95rem] text-white overflow-hidden line-clamp-2 min-w-0" id={`title-${v.id}`}>{v.title ?? "Sin título"}</h3>
                          {v.description && <p class="text-[.8rem] text-gray-500 overflow-hidden line-clamp-2 min-w-0">{String(v.description)}</p>}

                          <ul class="flex flex-wrap gap-y-1 gap-x-2.5 list-none p-0 mt-auto pt-2" aria-label="Metadatos">
                            {v.views !== undefined && (
                              <li><span class="text-[.72rem] bg-[#2a2a2a] border border-vs-border rounded px-1.5 py-[2px] text-gray-500 whitespace-nowrap tabular-nums" aria-label={`Vistas: ${formatViews(v.views)}`}>👁 {formatViews(v.views)}</span></li>
                            )}
                            {v.likes !== undefined && Number(v.likes) > 0 && (
                              <li><span class="text-[.72rem] bg-[#2a2a2a] border border-vs-border rounded px-1.5 py-[2px] text-gray-500 whitespace-nowrap">♥ {formatViews(v.likes)}</span></li>
                            )}
                            {v.cost !== undefined && (
                              <li><span class="text-[.72rem] bg-[#2a2a2a] border border-vs-border rounded px-1.5 py-[2px] text-gray-500 whitespace-nowrap">{formatCost(v.cost)}</span></li>
                            )}
                            {v.createdAt && (
                              <li><span class="text-[.72rem] bg-[#2a2a2a] border border-vs-border rounded px-1.5 py-[2px] text-gray-500 whitespace-nowrap">📅 {formatDate(v.createdAt)}</span></li>
                            )}
                          </ul>
                        </div>

                        {/* Botones */}
                        <div class="px-4 pb-3.5 flex gap-2 flex-wrap">
                          {canPlay ? (
                            <button
                              class="focusable inline-flex items-center gap-1.5 text-[.8rem] font-semibold px-3 py-1.5 rounded-[5px] cursor-pointer border-0 font-sans bg-blue-400 text-black hover:bg-blue-300 focus-visible:outline-2 focus-visible:outline-blue-300 focus-visible:outline-offset-2 transition-colors"
                              data-video-id={v.id}
                              aria-label={`Reproducir: ${v.title ?? v.id}`}
                            >
                              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5,3 19,12 5,21"/></svg>
                              {mode === "trailer" ? "Ver tráiler" : "Reproducir"}
                            </button>
                          ) : (
                            <button class="inline-flex items-center gap-1.5 text-[.8rem] font-semibold px-3 py-1.5 rounded-[5px] cursor-not-allowed border border-vs-border bg-transparent text-gray-500 opacity-40 font-sans" disabled>No disponible</button>
                          )}
                          {canPlay && mode !== "trailer" && v.publicUrls?.trailerManifest && (
                            <button
                              class="focusable inline-flex items-center gap-1.5 text-[.8rem] font-semibold px-3 py-1.5 rounded-[5px] cursor-pointer border border-vs-border bg-transparent text-gray-500 hover:border-blue-400 hover:text-blue-400 focus-visible:outline-2 focus-visible:outline-blue-300 focus-visible:outline-offset-2 transition-colors font-sans"
                              data-video-id={v.id}
                              data-force-trailer="true"
                              aria-label={`Ver tráiler de: ${v.title ?? v.id}`}
                            >
                              Tráiler
                            </button>
                          )}
                        </div>

                        {/* Detalles */}
                        <div class="px-4 pb-3.5">
                          <button
                            class="focusable text-[.73rem] text-gray-500 hover:text-blue-400 cursor-pointer bg-transparent border-0 p-0 flex items-center gap-1.5 transition-colors"
                            data-extra-id={v.id}
                            data-extra-json={JSON.stringify(v)}
                            aria-label={`Ver detalles de ${v.title ?? v.id}`}
                          >
                            <span class="text-[.55rem]">&#9656;</span>
                            Detalles
                          </button>
                        </div>

                        <p class="text-[.68rem] text-gray-700 font-mono px-4 pb-3">ID: {v.id}</p>
                      </article>
                    </li>
                  );
                })}
              </ol>
            </section>
          );
        })}
      </div>
    )}
  </main>

  {/* ─── Modal datos extra ─────────────────────────────────────────────────── */}
  <dialog
    id="extra-data-modal"
    aria-label="Detalles del video"
    aria-modal="true"
    class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0 bg-vs-bg border border-vs-border rounded-[10px] p-0 max-w-[min(720px,95vw)] w-[min(680px,92vw)] shadow-[0_24px_64px_rgba(0,0,0,.8)] [&::backdrop]:bg-black/60 [&::backdrop]:backdrop-blur-sm"
