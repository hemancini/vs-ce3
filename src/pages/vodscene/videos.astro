      transition: all 0.2s ease-in-out;
    }
    .focusable:focus, .focusable.nav-focused {
      box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.6) !important;
      border-color: #3b82f6 !important;
      transform: scale(1.03);
      z-index: 50;
      background-color: rgba(59, 130, 246, 0.1) !important;
    }
    /* Especial para los botones de reproducir que ya tienen fondo azul */
    button.focusable.bg-blue-400:focus, button.focusable.bg-blue-400.nav-focused {
      background-color: #60a5fa !important;
      box-shadow: 0 0 20px rgba(59, 130, 246, 0.8) !important;
    }
  </style>

  <script is:inline>
    // ─── Colapsar/expandir sección al hacer clic en su encabezado ──────────────
    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-section-toggle]");
      if (!btn) return;
      const section = btn.closest("section[data-section-id]");
      if (!section) return;
      const collapsed = section.dataset.collapsed === "true";
      section.dataset.collapsed = collapsed ? "" : "true";
      btn.setAttribute("aria-expanded", String(collapsed));
    });

    // ─── Toggle vista agrupada / lista ────────────────────────────────────────
    const container   = document.getElementById("sections-container");
    const btnGrouped  = document.getElementById("view-btn-grouped");
    const btnList     = document.getElementById("view-btn-list");
    const btnPoster   = document.getElementById("view-btn-poster");
    const btnHashtags = document.getElementById("view-btn-hashtags");
    const hashtagBar  = document.getElementById("hashtags-filter-bar");

    const BASE_BTN    = "focusable flex items-center gap-1.5 px-2.5 py-1.5 text-sm font-medium cursor-pointer transition-colors";
    const ACTIVE_CLS  = BASE_BTN + " bg-blue-500/20 text-blue-300 border-r border-vs-border";
    const INACTIVE_WITH_BORDER = BASE_BTN + " bg-transparent text-gray-400 hover:text-gray-200 border-r border-vs-border";
    const INACTIVE_LAST = BASE_BTN + " bg-transparent text-gray-400 hover:text-gray-200";

    let currentView = "grouped";
    let activeHashtag = "all";

    function setView(v) {
      const prev = currentView;
      currentView = v;
      // Si salimos de poster, restaurar imágenes originales
      if (prev === "poster" && v !== "poster") restorePosterImages();
      
      container.classList.toggle("view-grouped", v === "grouped");
      container.classList.toggle("view-list",    v === "list");
      container.classList.toggle("view-poster",  v === "poster");
      container.classList.toggle("view-hashtags", v === "hashtags");

      btnGrouped.setAttribute("aria-pressed", String(v === "grouped"));
      btnList.setAttribute("aria-pressed",    String(v === "list"));
      btnPoster.setAttribute("aria-pressed",  String(v === "poster"));
      btnHashtags.setAttribute("aria-pressed", String(v === "hashtags"));

      btnGrouped.className = v === "grouped" ? ACTIVE_CLS : INACTIVE_WITH_BORDER;
      btnList.className    = v === "list"    ? ACTIVE_CLS : INACTIVE_WITH_BORDER;
      btnPoster.className  = v === "poster"  ? ACTIVE_CLS : INACTIVE_WITH_BORDER;
      btnHashtags.className = v === "hashtags" ? ACTIVE_CLS.replace(" border-r border-vs-border", "") + " bg-blue-500/20 text-blue-300" : INACTIVE_LAST;

      if (hashtagBar) hashtagBar.classList.toggle("hidden", v !== "hashtags");
      
      // Si cambiamos a otra vista, reseteamos el filtro de hashtags
      if (v !== "hashtags" && activeHashtag !== "all") {
        activeHashtag = "all";
        updateHashtagChips();
      }

      // Re-apply filter and sort
      applyFilter();
      const sortSel = document.getElementById("video-sort");
      if (sortSel) applySort(sortSel.value);
      
      if (v === "poster") bindPosterHover();
    }

    function restorePosterImages() {
      document.querySelectorAll("li[data-poster-img] .poster-thumb-wrap img").forEach((img) => {
        const orig = img.dataset.originalSrc;
        if (orig) img.src = orig;
        img.dataset.posterSet = "";
      });
    }

    if (btnGrouped) btnGrouped.addEventListener("click", () => setView("grouped"));
    if (btnList)    btnList.addEventListener("click",    () => setView("list"));
    if (btnPoster)  btnPoster.addEventListener("click",  () => setView("poster"));
    if (btnHashtags) btnHashtags.addEventListener("click", () => setView("hashtags"));

    // ─── Lógica de filtros de hashtags ────────────────────────────────────────
    function updateHashtagChips() {
      container.querySelectorAll(".hashtag-chip").forEach(chip => {
        const isSelected = chip.dataset.tag === activeHashtag;
        if (isSelected) {
          chip.className = "hashtag-chip focusable px-3 py-1.5 rounded-full bg-blue-500 text-white text-xs font-semibold border border-blue-400 transition-colors cursor-pointer";
        } else {
          chip.className = "hashtag-chip focusable px-3 py-1.5 rounded-full bg-vs-surface border border-vs-border text-gray-400 text-xs font-semibold hover:border-blue-400 hover:text-blue-400 transition-colors cursor-pointer";
        }
      });
    }

    document.addEventListener("click", (e) => {
      const chip = e.target.closest(".hashtag-chip");
      if (!chip) return;
      activeHashtag = chip.dataset.tag;
      updateHashtagChips();
      applyFilter();
    });

    function bindPosterHover() {
      document.querySelectorAll("#sections-container.view-poster li[data-poster-img]").forEach((li) => {
        const posterImg  = li.dataset.posterImg;
        const trailerGif = li.dataset.trailerGif;
        if (!posterImg && !trailerGif) return;
        const img = li.querySelector(".poster-thumb-wrap img");
        if (!img) return;
        // Ensure poster image is set
        if (posterImg && img.dataset.posterSet !== "1") {
          img.src = posterImg;
          img.dataset.posterSet = "1";
        }
        if (!trailerGif) return;
        if (li.dataset.posterHoverBound === "1") return;
        li.dataset.posterHoverBound = "1";
        li.addEventListener("mouseenter", () => { img.src = trailerGif; });
        li.addEventListener("mouseleave", () => { img.src = posterImg || img.dataset.originalSrc || ""; });
      });
    }

    // ─── Buscador + ordenación ────────────────────────────────────────────────
    const searchInput = document.getElementById("video-search");
    const videoCount  = document.getElementById("video-count");
    const searchEmpty = document.getElementById("search-empty");
    const sortSelect  = document.getElementById("video-sort");

    if (container) {
      const totalLabel = videoCount ? videoCount.textContent : "";

      function getAllItems() {
        return Array.from(container.querySelectorAll("li[data-search]"));
      }

      function applyFilter() {
        const q = searchInput ? searchInput.value.trim().toLowerCase() : "";
        const allItems = getAllItems();
        let visible = 0;
        for (const li of allItems) {
          const searchMatch = !q || li.dataset.search.includes(q);
          const hashtagMatch = activeHashtag === "all" || 
                               (li.dataset.hashtags && JSON.parse(li.dataset.hashtags).includes(activeHashtag));
          
          const match = searchMatch && hashtagMatch;
          li.style.display = match ? "" : "none";
          if (match) visible++;
        }
        // En vista agrupada: ocultar secciones sin resultados
        for (const section of container.querySelectorAll("section[data-section-id]")) {
          const anyVisible = Array.from(section.querySelectorAll("li[data-search]"))
            .some((li) => li.style.display !== "none");
          section.dataset.hidden = anyVisible ? "" : "true";
          // Actualizar contador de la sección
          const badge = section.querySelector(".section-count");
          if (badge) {
            const sectionVisible = Array.from(section.querySelectorAll("li[data-search]"))
              .filter((li) => li.style.display !== "none").length;
            const total = Number(badge.dataset.total ?? 0);
            badge.textContent = q
              ? `${sectionVisible} de ${total}`
              : `${total} ${total === 1 ? "video" : "videos"}`;
          }
        }
        if (videoCount) {
          videoCount.textContent = q
            ? `${visible} resultado${visible !== 1 ? "s" : ""} de ${allItems.length}`
            : totalLabel;
        }
        if (searchEmpty) searchEmpty.classList.toggle("hidden", visible > 0 || !q);
      }

      function applySort(key) {
        const allItems = getAllItems();
        allItems.sort((a, b) => {
          switch (key) {
            case "date-asc":   return Number(a.dataset.created) - Number(b.dataset.created);
            case "date-desc":  return Number(b.dataset.created) - Number(a.dataset.created);
            case "title-asc":  return (a.dataset.title || "").localeCompare(b.dataset.title || "", "es");
            case "title-desc": return (b.dataset.title || "").localeCompare(a.dataset.title || "", "es");
            case "views-desc": return Number(b.dataset.views) - Number(a.dataset.views);
            case "views-asc":  return Number(a.dataset.views) - Number(b.dataset.views);
            case "likes-desc": return Number(b.dataset.likes) - Number(a.dataset.likes);
            case "likes-asc":  return Number(a.dataset.likes) - Number(b.dataset.likes);
            case "cost-desc":  return Number(b.dataset.cost)  - Number(a.dataset.cost);
            case "cost-asc":   return Number(a.dataset.cost)  - Number(b.dataset.cost);
            default: return 0;
          }
        });
        if (currentView === "list") {
          // En vista lista: asignar CSS order para que el grid plano quede ordenado
          allItems.forEach((el, i) => { el.style.order = String(i); });
        } else {
          // En vista agrupada: reordenar dentro de cada section-grid
          allItems.forEach((el) => { el.style.order = ""; });
          const sections = container.querySelectorAll("section[data-section-id]");
          for (const section of sections) {
            const grid = section.querySelector(".section-grid");
            if (!grid) continue;
            // Reordenar los li dentro del grid según el sort global
            const sectionItems = allItems.filter((li) => li.closest("section") === section);
            for (const li of sectionItems) grid.appendChild(li);
          }
        }
      }

      if (searchInput) searchInput.addEventListener("input", applyFilter);
      if (sortSelect)  sortSelect.addEventListener("change", () => applySort(sortSelect.value));
    }
  </script>

  <script is:inline>
    shaka.polyfill.installAll();

    const videoContainer = document.getElementById("video-container");
    const videoEl        = document.getElementById("player-video");
    const modalTitle    = document.getElementById("modal-title-text");
    const modeTag       = document.getElementById("modal-mode-tag");
    const modeDesc      = document.getElementById("modal-mode-desc");
    const errorDiv      = document.getElementById("player-error");

    let shakaPlayer = null;
    let shakaUi = null;
    let currentVideoLi = null;

    // Autoplay Countdown State
    let autoplayInterval = null;
    let autoplaySeconds = 3;
    let isAutoplayPaused = false;
    let nextVideoIdToPlay = null;

    const autoplayOverlay = document.getElementById("autoplay-overlay");
    const autoplayTimerEl = document.getElementById("autoplay-timer");
    const btnAutoplayCancel = document.getElementById("autoplay-cancel");
    const btnAutoplayPlayNow = document.getElementById("autoplay-play-now");
    const btnAutoplayPause = document.getElementById("autoplay-pause-resume");

    function cancelAutoplay() {
      if (autoplayInterval) { clearInterval(autoplayInterval); autoplayInterval = null; }
      autoplayOverlay.classList.remove("flex");
      autoplayOverlay.classList.add("hidden");
      nextVideoIdToPlay = null;
    }

    if (btnAutoplayCancel) btnAutoplayCancel.onclick = cancelAutoplay;
    if (btnAutoplayPlayNow) btnAutoplayPlayNow.onclick = () => {
      const id = nextVideoIdToPlay;
      cancelAutoplay();
      if (id) openPlayer(id);
    };
    if (btnAutoplayPause) btnAutoplayPause.onclick = () => {
      isAutoplayPaused = !isAutoplayPaused;
      btnAutoplayPause.textContent = isAutoplayPaused ? "Reanudar" : "Pausar";
      btnAutoplayPause.classList.toggle("bg-blue-500/20", isAutoplayPaused);
      btnAutoplayPause.classList.toggle("text-blue-300", isAutoplayPaused);
    };

    function showError(msg) { errorDiv.classList.remove("hidden"); errorDiv.textContent = "Error: " + msg; }
    function clearError()   { errorDiv.classList.add("hidden");    errorDiv.textContent = ""; }

    let isOpening = false;
    async function openPlayer(videoId, forceTrailer) {
      if (isOpening) return;
      isOpening = true;
      try {
        const data = window.__VIDEOS__[videoId];
        if (!data) return;

        // Limpiar cualquier autoplay pendiente si abrimos uno manualmente
        cancelAutoplay();

        // Guardar el LI actual para auto-play (playlist)
        currentVideoLi = document.querySelector(`li button[data-video-id="${videoId}"]`)?.closest('li');

        clearError();
        modalTitle.textContent = data.title;

        // Destruir instancia previa
        if (shakaUi)     { await shakaUi.destroy();     shakaUi = null; }
        if (shakaPlayer) { await shakaPlayer.destroy(); shakaPlayer = null; }

        videoEl.poster = data.poster || "";

        let manifestUrl = null;
        let drmServers  = {};
        let modeLabel   = "";
        let modeClass   = "";
        let modeTip     = "";

        const useTrailer = forceTrailer || data.mode === "trailer";

        if (useTrailer && data.trailer) {
          manifestUrl = data.trailer;
          modeLabel   = "Tráiler";
          modeClass   = "trailer";
          modeTip     = "HLS — sin DRM";
        } else if (data.mode === "nodrm" && data.dashNoDRM) {
          manifestUrl = data.dashNoDRM;
          modeLabel   = "Sin DRM";
          modeClass   = "nodrm";
          modeTip     = "DASH — reproducción libre";
        } else if (data.mode === "widevine" && data.dashDRM) {
          manifestUrl = data.dashDRM;
          modeLabel   = "Widevine DRM";
          modeClass   = "widevine";
          modeTip     = "DASH — protegido Widevine / PlayReady";
          if (data.widevineUrl)  drmServers["com.widevine.alpha"]      = data.widevineUrl;
          if (data.playreadyUrl) drmServers["com.microsoft.playready"] = data.playreadyUrl;
        }

        if (!manifestUrl) {
          showError("No hay URL de reproducción disponible.");
          videoContainer.classList.remove("hidden");
          videoContainer.classList.add("flex");
          return;
        }

        modeTag.textContent  = modeLabel;
        const modeTagClasses = {
          nodrm:   "text-[.7rem] font-bold px-[7px] py-[2px] rounded-[3px] tracking-wide bg-[#052e16] text-green-400 border border-[#166534]",
          widevine:"text-[.7rem] font-bold px-[7px] py-[2px] rounded-[3px] tracking-wide bg-[#0d1a2e] text-blue-300 border border-[#1e40af]",
          trailer: "text-[.7rem] font-bold px-[7px] py-[2px] rounded-[3px] tracking-wide bg-[#1c1007] text-amber-400 border border-[#92400e]",
        };
        modeTag.className    = modeTagClasses[modeClass] || "";
        modeDesc.textContent = modeTip;

        if (!shaka.Player.isBrowserSupported()) {
          showError("Tu navegador no soporta DASH. Usa Chrome o Firefox.");
          videoContainer.classList.remove("hidden");
          videoContainer.classList.add("flex");
          return;
        }

        // Usar el videoContainer declarado arriba
        shakaPlayer = new shaka.Player(videoEl);
        shakaPlayer.configure({
          streaming: {
            bufferingGoal: 30,
            rebufferingGoal: 2,
            bufferBehind: 60,
            stallEnabled: true,
            stallThreshold: 1,
            stallSkip: 0.1,
            gapDetectionThreshold: 0.5,
          }
        });

        // UI overlay con controles
        if (shaka.ui && shaka.ui.Overlay) {
          shakaUi = new shaka.ui.Overlay(shakaPlayer, videoContainer, videoEl);
          shakaUi.configure({
            controlPanelElements: ['play_pause','time_and_duration','spacer','mute','volume','fullscreen','overflow_menu']
          });
        }

        shakaPlayer.addEventListener("error", (event) => {
          const err = event.detail;
          showError("Shaka " + err.code + ": " + (err.message || "error de reproducción"));
        });

        // ─── Watchdog: si el video queda en "waiting" más de 5s, microseek para desatascar ───
        let stallWatchdog = null;
        videoEl.addEventListener("waiting", () => {
          clearTimeout(stallWatchdog);
          stallWatchdog = setTimeout(() => {
            if (videoEl.readyState < 3 && !videoEl.paused) {
              const t = videoEl.currentTime;
              videoEl.currentTime = t + 0.1;
            }
          }, 5000);
        });
        videoEl.addEventListener("playing", () => { clearTimeout(stallWatchdog); stallWatchdog = null; });
        videoEl.addEventListener("pause",   () => { clearTimeout(stallWatchdog); stallWatchdog = null; });

        // ─── Request filter: CustomData para EZDRM ─────────────────────
        shakaPlayer.getNetworkingEngine().registerRequestFilter((type, request) => {
          if (type !== shaka.net.NetworkingEngine.RequestType.LICENSE) return;
          const uri = request.uris[0];
          if (!uri || !uri.includes("ezdrm.com")) return;

          const customData = encodeURIComponent(JSON.stringify({
            userId:  data.uploadedBy || "LH4KxJwmTYZPgIFVZzQuoMNGzfq1",
            videoId: videoId
          }));
          request.uris[0] = uri + (uri.includes("?") ? "&" : "?") + "CustomData=" + customData;

          request.headers["accept"]           = "*/*";
          request.headers["accept-language"]  = "en-US,en;q=0.9";
          request.headers["Referer"]          = "https://vodscene.com/";
          request.headers["Content-Type"]     = "text/plain;charset=UTF-8";
          request.headers["sec-fetch-dest"]   = "empty";
          request.headers["sec-fetch-mode"]   = "cors";
          request.headers["sec-fetch-site"]   = "cross-site";
        });

        // ─── Configurar DRM ────────────────────────────────────────────
        if (Object.keys(drmServers).length > 0) {
          shakaPlayer.configure({ drm: { servers: drmServers } });
        }

        try {
          await shakaPlayer.load(manifestUrl);
          // Mostrar contenedor y solicitar pantalla completa
          videoContainer.classList.remove("hidden");
          videoContainer.classList.add("flex");
          
          if (videoContainer.requestFullscreen) {
            videoContainer.requestFullscreen().catch(() => {});
          } else if (videoContainer.webkitRequestFullscreen) {
            videoContainer.webkitRequestFullscreen();
          }

          videoEl.play().catch(() => {});
        } catch (err) {
          showError(err.message || "No se pudo cargar el video.");
          // Destruir el player para que el spinner de Shaka no quede visible
          if (shakaUi)     { try { await shakaUi.destroy();     } catch (_) {} shakaUi = null; }
          if (shakaPlayer) { try { await shakaPlayer.destroy(); } catch (_) {} shakaPlayer = null; }
          videoEl.removeAttribute("src");
          videoContainer.classList.remove("hidden");
          videoContainer.classList.add("flex");
        }
      } catch (e) {
        showError(e.message || "Error al inicializar el reproductor.");
        videoContainer.classList.remove("hidden");
        videoContainer.classList.add("flex");
      } finally {
        isOpening = false;
      }
    }

    async function closePlayer() {
      if (document.fullscreenElement || document.webkitFullscreenElement) {
        if (document.exitFullscreen) document.exitFullscreen().catch(() => {});
        else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
      }
      
      videoEl.pause();
      if (shakaUi)     { await shakaUi.destroy();     shakaUi = null; }
      if (shakaPlayer) { await shakaPlayer.destroy(); shakaPlayer = null; }
      videoEl.removeAttribute("src");
      videoEl.poster = "";
      clearError();
      cancelAutoplay();
      videoContainer.classList.remove("flex");
      videoContainer.classList.add("hidden");
      currentVideoLi = null;
    }

    // Auto-play: Al terminar un video, reproducir el anterior del mismo grupo
    // (los videos están ordenados por fecha descendente, así que "siguiente" = previousElementSibling)
    videoEl.addEventListener('ended', () => {
      if (!currentVideoLi) return;
      
      let nextLi = currentVideoLi.previousElementSibling;
      // Buscar el anterior que no esté oculto por filtros
      while (nextLi && (nextLi.style.display === 'none' || !nextLi.querySelector('[data-video-id]'))) {
        nextLi = nextLi.previousElementSibling;
      }

      if (nextLi) {
        const nextBtn = nextLi.querySelector('[data-video-id]');
        if (nextBtn) {
          const nextId = nextBtn.dataset.videoId;
          startAutoplayCountdown(nextId);
        }
      }
    });

    function startAutoplayCountdown(id) {
      if (autoplayInterval) clearInterval(autoplayInterval);
      
      nextVideoIdToPlay = id;
      autoplaySeconds = 3;
      isAutoplayPaused = false;
      
      autoplayTimerEl.textContent = autoplaySeconds;
      btnAutoplayPause.textContent = "Pausar";
      btnAutoplayPause.className = "flex-1 px-4 py-2 bg-white/10 hover:bg-white/20 rounded-lg text-sm font-bold transition-colors border border-white/10";
      
      autoplayOverlay.classList.remove("hidden");
      autoplayOverlay.classList.add("flex");

      autoplayInterval = setInterval(() => {
        if (!isAutoplayPaused) {
          autoplaySeconds--;
          autoplayTimerEl.textContent = Math.max(0, autoplaySeconds);
          if (autoplaySeconds <= 0) {
            const finalId = nextVideoIdToPlay;
            cancelAutoplay();
            if (finalId) openPlayer(finalId);
          }
        }
      }, 1000);
    }

    // Cerrar si se sale de pantalla completa
    document.addEventListener("fullscreenchange", () => {
      if (!document.fullscreenElement && !videoContainer.classList.contains("hidden")) {
        closePlayer();
      }
    });
    document.addEventListener("webkitfullscreenchange", () => {
      if (!document.webkitFullscreenElement && !videoContainer.classList.contains("hidden")) {
        closePlayer();
      }
    });

    // La navegación y cierre se manejan via fullscreenchange o controles de Shaka

    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-video-id]");
      if (!btn) return;
      openPlayer(btn.dataset.videoId, btn.dataset.forceTrailer === "true");
    });

    // ─── Extra data modal ─────────────────────────────────────────────────────
    const extraModal      = document.getElementById("extra-data-modal");
    const extraPanelDet   = document.getElementById("extra-panel-details");
    const extraPanelRaw   = document.getElementById("extra-panel-raw");
    const extraModalPre   = document.getElementById("extra-modal-content");
    const extraModalClose = document.getElementById("extra-modal-close");
    const tabBtnDet       = document.getElementById("tab-btn-details");
    const tabBtnRaw       = document.getElementById("tab-btn-raw");

    function switchTab(tab) {
      const isDet = tab === "details";
      extraPanelDet.classList.toggle("hidden", !isDet);
      extraPanelRaw.classList.toggle("hidden",  isDet);
      tabBtnDet.className = isDet
        ? "text-sm font-medium px-1 py-3 mr-5 border-b-2 border-red-500 text-white cursor-pointer bg-transparent"
        : "text-sm font-medium px-1 py-3 mr-5 border-b-2 border-transparent text-gray-500 hover:text-gray-300 cursor-pointer bg-transparent transition-colors";
      tabBtnRaw.className = !isDet
        ? "text-sm font-medium px-1 py-3 border-b-2 border-red-500 text-white cursor-pointer bg-transparent"
        : "text-sm font-medium px-1 py-3 border-b-2 border-transparent text-gray-500 hover:text-gray-300 cursor-pointer bg-transparent transition-colors";
    }

    tabBtnDet.addEventListener("click", () => switchTab("details"));
    tabBtnRaw.addEventListener("click", () => switchTab("raw"));

    extraModalClose.addEventListener("click", () => extraModal.close());
    extraModal.addEventListener("cancel", () => extraModal.close());
    extraModal.addEventListener("click", (e) => { if (e.target === extraModal) extraModal.close(); });

    function esc(s) { return String(s ?? "—").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
    function lbl(t) { return `<div class="text-[.68rem] font-semibold text-gray-500 uppercase tracking-wider mb-1">${t}</div>`; }
    function val(v, cls = "text-gray-200 text-sm") { return `<div class="${cls}">${esc(v)}</div>`; }
    function codebox(v) { return `<div class="bg-[#111] border border-[#2d2d2d] rounded px-3 py-2 text-[.78rem] font-mono text-gray-300 break-all">${esc(v)}</div>`; }
    function field(l, v, cls)  { return `<div>${lbl(l)}${val(v, cls)}</div>`; }
    function fieldCode(l, v)   { return `<div>${lbl(l)}${codebox(v)}</div>`; }

    function buildDetails(data) {
      const cost        = data.cost ? Number(data.cost) : 0;
      const costStr     = !cost ? "Gratis" : new Intl.NumberFormat("es-AR",{style:"currency",currency:"ARS",maximumFractionDigits:0}).format(cost);
      const createdAt   = data.createdAt ? new Intl.DateTimeFormat("en",{dateStyle:"short"}).format(new Date(data.createdAt)) : null;
      const participants = Array.isArray(data.participants)
        ? data.participants.map(p => typeof p === "object" && p !== null ? (p.name ?? p.displayName ?? p.id ?? p.slug ?? JSON.stringify(p)) : String(p)).join(", ")
        : (data.participants ?? null);
      const manifestUrl  = data.publicUrls?.dashManifestNoDRM || data.publicUrls?.dashManifest || data.publicUrls?.trailerManifest;
      const keyId        = data.drm?.keyId;
      const fpIv         = data.fairplay?.ivHex;

      let html = '<div class="p-5 space-y-5 text-sm">';

      // ─ Grid 2 columnas ─
      const gridCells = [];
      if (participants)         gridCells.push(field("Participants", participants));
      if (data.cost !== undefined) gridCells.push(field("Cost", costStr, cost > 0 ? "text-green-400 text-sm font-semibold" : "text-gray-200 text-sm"));
      if (data.processingStatus) gridCells.push(field("Processing Status", data.processingStatus));
      if (createdAt)            gridCells.push(field("Created At", createdAt));
      if (data.isActive !== undefined) gridCells.push(field("Active", data.isActive ? "Yes" : "No"));
      if (data.uploadedBy)      gridCells.push(field("Uploaded By", data.uploadedBy));

      if (gridCells.length) {
        html += `<div class="grid grid-cols-2 gap-x-8 gap-y-4 border-b border-[#2d2d2d] pb-5">${gridCells.join("")}</div>`;
      }

      // ─ Descripción ─
      if (data.description) {
        html += `<div class="border-b border-[#2d2d2d] pb-5">${field("Description", data.description)}</div>`;
      }

      // ─ Manifest URL ─
      if (manifestUrl) {
        html += `<div class="border-b border-[#2d2d2d] pb-5">${fieldCode("Manifest URL", manifestUrl)}</div>`;
      }

      // ─ DRM Keys ─
      if (keyId || fpIv) {
        html += '<div class="space-y-3">';
        html += '<div class="text-red-400 text-[.8rem] font-bold uppercase tracking-wider flex items-center gap-1.5">🔒 DRM Keys</div>';
        if (keyId) html += fieldCode("Key ID (Widevine/Common)", keyId);
        if (fpIv)  html += fieldCode("FairPlay IV", fpIv);
        html += '</div>';
      }

      html += '</div>';
      return html;
    }

    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-extra-id]");
      if (!btn) return;
      const rawJson = btn.dataset.extraJson;
      if (!rawJson) return;
      const data = JSON.parse(rawJson);
      switchTab("details");
      extraPanelDet.innerHTML = buildDetails(data);
      extraModalPre.textContent = JSON.stringify(data, null, 2);
      extraModal.showModal();
    });

    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-popup-id]");
      if (!btn) return;
      const id      = btn.dataset.popupId;
      const trailer = btn.dataset.popupTrailer === "1" ? "&trailer=1" : "";
      window.open(
        `/vodscene/player?id=${id}${trailer}`,
        `player-${id}`,
        "popup,width=960,height=560,resizable=yes"
      );
    });

    // ─── GIF preview on hover ──────────────────────────────────────────────────
    // ─── Previsualización GIF y Tráiler Inline al enfocar ─────────────────────
    let previewPlayer = null;
    const previewVideo = document.createElement("video");
    previewVideo.muted = true;
    previewVideo.autoplay = true;
    previewVideo.setAttribute("playsinline", "");
    previewVideo.className = "absolute inset-0 w-full h-full object-cover z-[5] bg-black";

    async function closePreview() {
      if (autoplayTimer) { clearTimeout(autoplayTimer); autoplayTimer = null; }
      if (previewPlayer) {
        const p = previewPlayer;
        previewPlayer = null; // Evitar reentrada
        await p.destroy();
      }
      previewVideo.pause();
      previewVideo.removeAttribute("src");
      previewVideo.load();
      if (previewVideo.parentElement) previewVideo.parentElement.removeChild(previewVideo);
    }

    async function openPreview(videoId, container) {
      if (isOpening) return;
      const data = window.__VIDEOS__[videoId];
      if (!data || !data.trailer) return;

      // Limpiar previo
      if (previewPlayer) { await previewPlayer.destroy(); previewPlayer = null; }
      
      container.appendChild(previewVideo);
      previewPlayer = new shaka.Player(previewVideo);
      previewPlayer.configure({
        streaming: {
          bufferingGoal: 30,
          rebufferingGoal: 10,
          bufferBehind: 60,
        }
      });
      
      // Configuración básica (sin UI para preview)
      try {
        await previewPlayer.load(data.trailer);
      } catch (e) {
        console.warn("Preview load failed", e);
        closePreview();
      }
    }

    let autoplayTimer = null;
    document.addEventListener("focus", (e) => {
      const focusable = e.target.closest("[data-video-id]");
      if (!focusable) return;

      const cardWrap = focusable.closest("[data-gif]");
      const videoId  = focusable.dataset.videoId;
      if (!cardWrap || !videoId) return;

      // GIF inmediato
      const gif = cardWrap.dataset.gif;
      const img = cardWrap.querySelector("img");
      if (img && gif) img.src = gif;

      // Tráiler inline tras 1.2s
      if (autoplayTimer) clearTimeout(autoplayTimer);
      autoplayTimer = setTimeout(() => {
        if (document.activeElement === focusable) {
          const thumbWrap = cardWrap.querySelector(".poster-thumb-wrap");
          if (thumbWrap) openPreview(videoId, thumbWrap);
        }
      }, 1200);
    }, true);

    document.addEventListener("blur", (e) => {
      const focusable = e.target.closest("[data-video-id]");
      if (!focusable) return;

      const cardWrap = focusable.closest("[data-gif]");
      if (!cardWrap) return;

      const img = cardWrap.querySelector("img");
      const original = img ? img.dataset.originalSrc : null;
      if (img && original) img.src = original;

      closePreview();
    }, true);

    // Mantener también el mouseover para usuarios con mouse
    document.querySelectorAll("[data-gif]").forEach((wrap) => {
      const gif = wrap.dataset.gif;
      const img = wrap.querySelector("img");
      if (!img || !gif) return;
      const original = img.src;
      wrap.addEventListener("mouseenter", () => { img.src = gif; });
      wrap.addEventListener("mouseleave", () => { img.src = original; });
    });

    // Drag logic removed


    // Fin de openPlayer logic
  </script>
</Layout>
