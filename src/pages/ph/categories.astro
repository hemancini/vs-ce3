---
// Listado de categorías: /ph/categories → https://es.pornhub.com/categories
// Cada tarjeta enlaza a /ph/categories/<slug> o /ph/video?c=<id> (videos de la categoría).
import Layout from "../../layouts/Ph.astro";
import PhHeader from "../../components/ph/PhHeader.astro";
import { scrapeCategories } from "../../lib/ph/scraper.js";

export const prerender = false;

const env = (Astro.locals as any)?.runtime?.env;

let categories = [];
let languages = [];
let error = null;
const startedAt = Date.now();

try {
  const result = await scrapeCategories({ env });
  categories = result.categories;
  languages = result.languages;
} catch (e) {
  error = e.message;
}

let cookieFromKV = false;
let cookieCount = 0;
try {
  const raw = await env?.VS_C3_KV?.get("ph:cookies");
  if (raw) { cookieFromKV = true; cookieCount = JSON.parse(raw).length; }
} catch {}

const elapsed = ((Date.now() - startedAt) / 1000).toFixed(1);

// videosNum llega como "121,632"; lo normalizamos a número para poder ordenar.
const toNum = (s) => parseInt(String(s || "").replace(/[^\d]/g, ""), 10) || 0;
---

<Layout title="LustHub - Categorías">
  <PhHeader
    title="📂 Categorías"
    stats={error ? "Error al scrapear" : `${categories.length} categorías · ${elapsed}s`}
    cookieFromKV={cookieFromKV}
    cookieCount={cookieCount}
    nav={["scraper", "pornstars"]}
    sourceUrl="https://es.pornhub.com/categories"
  />

  <!-- Toolbar sticky: la búsqueda/orden siguen accesibles al hacer scroll. -->
  <div class="sticky top-0 z-20 -mx-2 px-2 py-2 bg-vs-bg/90 backdrop-blur supports-backdrop-filter:bg-vs-bg/70">
    <div class="max-w-[1600px] mx-auto flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3">
      <div class="relative flex-1 min-w-0">
        <input
          id="search"
          type="search"
          placeholder="Filtrar categorías por nombre…  (pulsa /)"
          class="w-full bg-vs-surface text-white placeholder-gray-500 border border-vs-border rounded-lg pl-4 pr-10 py-2.5 outline-none focus:border-vs-pink"
        />
        <button
          id="clear"
          type="button"
          aria-label="Limpiar búsqueda"
          class="hidden absolute right-2 top-1/2 -translate-y-1/2 w-7 h-7 text-center leading-7 rounded-md text-gray-400 hover:text-white hover:bg-vs-border cursor-pointer"
        >✕</button>
      </div>
      <select
        id="sort"
        aria-label="Ordenar categorías"
        class="w-full sm:w-auto bg-vs-surface text-white border border-vs-border rounded-lg px-3 py-2.5 outline-none focus:border-vs-pink cursor-pointer"
      >
        <option value="">Orden original</option>
        <option value="videos">Más vídeos</option>
        <option value="name">Nombre A-Z</option>
      </select>
    </div>
  </div>

  {languages.length > 0 && (
    <section class="max-w-[1600px] mx-auto mt-4">
      <h2 class="text-base font-semibold text-gray-300 m-0 mb-3">Idioma en los vídeos</h2>
      <div class="flex flex-wrap gap-2">
        {languages.map((lang) => (
          <a
            href={lang.href}
            class="px-3 py-1.5 bg-vs-surface border border-vs-border rounded-full text-sm text-gray-300 no-underline hover:text-white hover:border-vs-pink"
          >{lang.name}</a>
        ))}
      </div>
    </section>
  )}

  {error && <p class="text-center text-red-500 my-8">No se pudo scrapear: {error}</p>}
  {!error && categories.length === 0 && <p class="text-center text-gray-500 my-8">Sin resultados.</p>}

  <h2 class="max-w-[1600px] mx-auto mt-6 text-base font-semibold text-gray-300">Categorías</h2>

  <div
    id="grid"
    class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-[repeat(auto-fill,minmax(220px,1fr))] gap-3 sm:gap-5 max-w-[1600px] mx-auto mt-4"
  >
    {categories.map((cat) => (
      <a
        href={cat.href}
        class="card group bg-vs-surface rounded-xl overflow-hidden no-underline block transition-transform duration-200 active:scale-[0.98] md:hover:-translate-y-1"
        data-name={cat.name}
        data-videos={toNum(cat.videosNum)}
      >
        <div class="relative aspect-video bg-black">
          <img class="w-full h-full object-cover transition-transform duration-300 md:group-hover:scale-105" src={cat.thumbnail} loading="lazy" alt={cat.name} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
          {cat.videosNum && (
            <span class="absolute top-2 right-2 px-1.5 py-0.5 rounded-md bg-black/70 text-white text-[11px] font-medium tabular-nums">
              {cat.videosNum}
            </span>
          )}
          <h3 class="absolute bottom-2 left-3 right-3 m-0 text-white font-semibold leading-snug line-clamp-2 group-hover:text-vs-pink">
            {cat.name}
          </h3>
        </div>
      </a>
    ))}
  </div>

  <p id="empty" class="hidden text-center text-gray-500 my-8">Sin coincidencias.</p>

  <script is:inline>
    const grid = document.getElementById("grid");
    const searchEl = document.getElementById("search");
    const sortEl = document.getElementById("sort");
    const clearEl = document.getElementById("clear");
    const statsEl = document.getElementById("stats");
    const emptyEl = document.getElementById("empty");
    const cards = [...grid.querySelectorAll(".card")];
    const total = cards.length;
    // Orden inicial para poder restaurar "Orden original".
    cards.forEach((c, i) => (c.dataset.idx = i));

    function apply() {
      const term = searchEl.value.trim().toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const ok = !term || (card.dataset.name || "").toLowerCase().includes(term);
        card.classList.toggle("hidden", !ok);
        if (ok) visible++;
      }

      const sort = sortEl.value;
      const cmp = {
        videos: (a, b) => (+b.dataset.videos || 0) - (+a.dataset.videos || 0),
        name: (a, b) => (a.dataset.name || "").localeCompare(b.dataset.name || "", "es"),
        "": (a, b) => (+a.dataset.idx) - (+b.dataset.idx),
      }[sort];
      if (cmp) for (const c of [...cards].sort(cmp)) grid.appendChild(c);

      emptyEl.classList.toggle("hidden", visible > 0);
      clearEl.classList.toggle("hidden", !term);
      if (statsEl) {
        statsEl.textContent = term
          ? `${visible} / ${total} categorías`
          : `${total} categorías`;
      }
    }

    searchEl.addEventListener("input", apply);
    sortEl.addEventListener("change", apply);
    clearEl.addEventListener("click", () => {
      searchEl.value = "";
      searchEl.focus();
      apply();
    });

    // Atajos de teclado: "/" enfoca la búsqueda, Escape la limpia.
    document.addEventListener("keydown", (e) => {
      if (e.key === "/" && document.activeElement !== searchEl) {
        e.preventDefault();
        searchEl.focus();
      } else if (e.key === "Escape" && document.activeElement === searchEl) {
        searchEl.value = "";
        apply();
      }
    });
  </script>
</Layout>
