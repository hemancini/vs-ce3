---
// Videos de una categoría: /ph/categories/<slug> → https://es.pornhub.com/categories/<slug>
import Layout from "../../../layouts/Ph.astro";
import PhHeader from "../../../components/ph/PhHeader.astro";
import PhScraperControls from "../../../components/ph/PhScraperControls.astro";
import PhCategoryChips from "../../../components/ph/PhCategoryChips.astro";
import VideoGrid from "../../../components/ph/VideoGrid.astro";
import { scrapeSource } from "../../../lib/ph/scraper.js";

export const prerender = false;

const env = (Astro.locals as any)?.runtime?.env;
const category = Astro.params.category ?? "";

const params = Astro.url.searchParams;
const pages = Math.min(Math.max(parseInt(params.get("paginas") || "1", 10) || 1, 1), 20);
const q = (params.get("q") || "").trim();
const withStreams = params.get("streams") === "1";

const listUrl = `https://es.pornhub.com/categories/${category}`;

let videos = [];
let totalPages = 0;
let total = 0;
let chips = [];
let error = null;
const startedAt = Date.now();

try {
  const result = await scrapeSource({ listUrl, label: category, maxPages: pages, withStreams, env });
  videos = result.videos;
  totalPages = result.totalPages;
  total = result.total;
  chips = result.chips;
} catch (e) {
  error = e.message;
}

let cookieFromKV = false;
let cookieCount = 0;
try {
  const raw = await env?.VS_C3_KV?.get("ph:cookies");
  if (raw) { cookieFromKV = true; cookieCount = JSON.parse(raw).length; }
} catch {}

const elapsed = ((Date.now() - startedAt) / 1000).toFixed(1);
const prettyName = decodeURIComponent(category).replace(/-/g, " ");
---

<Layout title={`LustHub - ${prettyName}`}>
  <PhHeader
    title={`📂 ${prettyName}`}
    capitalize
    stats={error ? "Error al scrapear" : `${videos.length} videos · ${elapsed}s · ${totalPages} págs.`}
    cookieFromKV={cookieFromKV}
    cookieCount={cookieCount}
    sourceUrl={`https://es.pornhub.com/categories/${category}`}
  >
    <PhScraperControls pages={pages} withStreams={withStreams} q={q} />
  </PhHeader>

  <PhCategoryChips chips={chips} activeSlug={category} total={total} />

  <VideoGrid
    videos={videos}
    totalPages={totalPages}
    nextPage={pages + 1}
    listUrl={listUrl}
    withStreams={withStreams}
    q={q}
    error={error}
  />
</Layout>
