---
// Suscripciones de un usuario: /ph/users/<id>/subscriptions
// → https://es.pornhub.com/users/<id>/subscriptions
// Misma estructura de URL que el sitio real. Lista los performers a los que el
// usuario está suscrito (no videos), así que renderiza tarjetas de performer.
import Layout from "../../../../layouts/Ph.astro";
import PhHeader from "../../../../components/ph/PhHeader.astro";
import PornstarCard from "../../../../components/ph/PornstarCard.astro";
import { scrapeSubscriptions } from "../../../../lib/ph/scraper.js";

export const prerender = false;

const env = (Astro.locals as any)?.runtime?.env;
const id = Astro.params.id ?? "";

let subscriptions = [];
let error = null;
const startedAt = Date.now();

try {
  const result = await scrapeSubscriptions({ id, env });
  subscriptions = result.subscriptions;
} catch (e) {
  error = e.message;
}

let cookieFromKV = false;
let cookieCount = 0;
try {
  const raw = await env?.VS_C3_KV?.get("ph:cookies");
  if (raw) { cookieFromKV = true; cookieCount = JSON.parse(raw).length; }
} catch {}

const elapsed = ((Date.now() - startedAt) / 1000).toFixed(1);
---

<Layout title="LustHub - Suscripciones">
  <PhHeader
    title="🔔 Suscripciones"
    stats={error ? "Error al scrapear" : `${subscriptions.length} · ${elapsed}s`}
    cookieFromKV={cookieFromKV}
    cookieCount={cookieCount}
    sourceUrl={`https://es.pornhub.com/users/${id}/subscriptions`}
  />

  {error && <p class="text-center text-red-500 my-8">No se pudo scrapear: {error}</p>}
  {!error && subscriptions.length === 0 && <p class="text-center text-gray-500 my-8">Sin suscripciones.</p>}

  <div
    id="grid"
    class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3 sm:gap-5 max-w-[1600px] mx-auto"
  >
    {subscriptions.map((star) => <PornstarCard star={star} />)}
  </div>
</Layout>
