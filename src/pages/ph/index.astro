---
// Los videos se cargan en runtime desde /api/ph/videos.json, así un nuevo
// scraping se refleja al refrescar sin necesidad de rebuild.
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="es" class="bg-vs-bg">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LustHub - Reproductor</title>
  <script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.13/dist/hls.min.js"></script>
</head>
<body class="m-0 p-5 bg-vs-bg text-white font-sans">
  <h1 class="text-center text-vs-pink text-3xl font-bold">🎬 LustHub - Reproductor</h1>
  <p class="text-center -mt-2.5">
    <a href="/ph/scraper" class="text-vs-pink no-underline font-bold">🕷️ Ir al scraper</a>
  </p>

  <div class="max-w-[1600px] mx-auto mb-4 flex justify-center gap-2" id="tabs">
    <button data-src="model" class="tab px-5 py-2 rounded-lg border border-vs-border cursor-pointer transition-colors">🎬 Modelo</button>
    <button data-src="favorites" class="tab px-5 py-2 rounded-lg border border-vs-border cursor-pointer transition-colors">⭐ Favoritos</button>
  </div>

  <div class="max-w-[1600px] mx-auto mb-5 flex flex-wrap items-center gap-3">
    <input
      id="search"
      type="search"
      placeholder="Buscar por título…"
      class="flex-1 min-w-[220px] bg-vs-surface text-white placeholder-gray-500 border border-vs-border rounded-lg px-4 py-2.5 outline-none focus:border-vs-pink"
    />
    <select id="uploader" class="bg-vs-surface text-white border border-vs-border rounded-lg px-3 py-2.5 outline-none focus:border-vs-pink cursor-pointer">
      <option value="">Todos los canales</option>
    </select>
    <select id="quality" class="bg-vs-surface text-white border border-vs-border rounded-lg px-3 py-2.5 outline-none focus:border-vs-pink cursor-pointer">
      <option value="">Cualquier calidad</option>
      <option value="1080">1080p+</option>
      <option value="720">720p+</option>
      <option value="480">480p+</option>
    </select>
    <select id="sort" class="bg-vs-surface text-white border border-vs-border rounded-lg px-3 py-2.5 outline-none focus:border-vs-pink cursor-pointer">
      <option value="">Orden original</option>
      <option value="views">Más vistas</option>
      <option value="duration-desc">Más largos</option>
      <option value="duration-asc">Más cortos</option>
    </select>
    <button id="reset" class="px-3 py-2.5 bg-vs-surface border border-vs-border rounded-lg text-gray-300 hover:text-white hover:border-vs-pink cursor-pointer">Limpiar</button>
    <span id="count" class="text-sm text-gray-500 whitespace-nowrap"></span>
  </div>

  <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-5 max-w-[1600px] mx-auto" id="grid"></div>

  <div id="modal" class="hidden fixed inset-0 bg-black/95 items-center justify-center z-[1000]">
    <div class="w-[95%] max-w-[1100px] bg-[#111] rounded-xl overflow-hidden">
      <span class="absolute top-[15px] right-[25px] text-[2.8rem] text-white cursor-pointer z-10" id="close">×</span>
      <div class="relative pt-[56.25%]">
        <video id="video" class="absolute top-0 left-0 w-full h-full bg-black" controls autoplay></video>
      </div>
      <div class="px-5 py-4">
        <h2 id="modal-title" class="text-xl font-semibold"></h2>
        <button id="open-original" class="p-2 mt-2 w-full bg-vs-pink text-white border-0 rounded-md cursor-pointer">
          Abrir en Pornhub (Recomendado)
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    let hls = null;
    const grid = document.getElementById('grid');
    const modal = document.getElementById('modal');
    const videoEl = document.getElementById('video');
    const titleEl = document.getElementById('modal-title');
    const openBtn = document.getElementById('open-original');

    const searchEl = document.getElementById('search');
    const uploaderEl = document.getElementById('uploader');
    const qualityEl = document.getElementById('quality');
    const sortEl = document.getElementById('sort');
    const resetEl = document.getElementById('reset');
    const countEl = document.getElementById('count');

    let currentVideo = null;
    let playToken = 0;
    let allVideos = [];

    // ── Helpers de parseo ─────────────────────────────────────────────
    // "616K" → 616000, "1.2M" → 1200000, "1,234" → 1234
    function parseViews(s) {
      if (!s) return 0;
      const m = String(s).trim().replace(/,/g, '').match(/^([\d.]+)\s*([KMB])?/i);
      if (!m) return 0;
      const mult = { K: 1e3, M: 1e6, B: 1e9 }[(m[2] || '').toUpperCase()] || 1;
      return Math.round(parseFloat(m[1]) * mult);
    }

    // "16:12" → 972s, "1:02:03" → 3723s
    function parseDuration(s) {
      if (!s) return 0;
      const parts = String(s).split(':').map(Number);
      if (parts.some(isNaN)) return 0;
      return parts.reduce((acc, n) => acc * 60 + n, 0);
    }

    // Máxima resolución disponible entre los streams (1080, 720, …)
    function maxQuality(streams) {
      return (streams || []).reduce((max, s) => {
        const q = parseInt(s.quality, 10);
        return !isNaN(q) && q > max ? q : max;
      }, 0);
    }

    // Todo el media del CDN de Pornhub se sirve a través de /api/ph/proxy (mismo
    // origen): evita el bloqueo CORS de hls.js y añade el Referer que exige el CDN
    // (sin él las previews/streams devuelven 410 "hotlink denegado").
    const proxied = (u) => `/api/ph/proxy?url=${encodeURIComponent(u)}`;

    function renderGrid(videos) {
      grid.innerHTML = '';
      videos.forEach(video => {
        const card = document.createElement('div');
        card.className = 'bg-vs-surface rounded-xl overflow-hidden cursor-pointer transition-transform duration-200 hover:-translate-y-2';
        card.innerHTML = `
          <div class="relative aspect-video bg-black">
            <img class="w-full h-full object-cover" src="${video.thumbnail}" loading="lazy">
            <video class="preview absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 pointer-events-none" muted loop playsinline preload="none"></video>
            ${video.duration ? `<div class="absolute bottom-2 right-2 bg-black/85 px-2 py-1 rounded text-sm font-bold">${video.duration}</div>` : ''}
          </div>
          <div class="p-3.5">
            <h3 class="m-0 mb-2 leading-snug text-[1.05rem]">${video.title}</h3>
          </div>
        `;
        card.addEventListener('click', () => playVideo(video));

        // Vista previa al hacer hover: cargamos el .webm de forma perezosa
        // (solo al entrar el cursor) para no descargar todas las previews.
        if (video.preview) {
          const prev = card.querySelector('.preview');
          card.addEventListener('mouseenter', () => {
            if (!prev.src) prev.src = proxied(video.preview);
            prev.currentTime = 0;
            prev.play().then(() => {
              prev.classList.remove('opacity-0');
              prev.classList.add('opacity-100');
            }).catch(() => {});
          });
          card.addEventListener('mouseleave', () => {
            prev.classList.add('opacity-0');
            prev.classList.remove('opacity-100');
            prev.pause();
          });
        }

        grid.appendChild(card);
      });
    }

    function applyFilter() {
      const q = searchEl.value.trim().toLowerCase();
      const uploader = uploaderEl.value;
      const minQuality = parseInt(qualityEl.value, 10) || 0;
      const sort = sortEl.value;

      let list = allVideos.filter(v => {
        if (q && !(v.title || '').toLowerCase().includes(q)) return false;
        if (uploader && (v.uploader?.name || '') !== uploader) return false;
        if (minQuality && maxQuality(v.streams) < minQuality) return false;
        return true;
      });

      if (sort === 'views') {
        list = [...list].sort((a, b) => parseViews(b.views) - parseViews(a.views));
      } else if (sort === 'duration-desc') {
        list = [...list].sort((a, b) => parseDuration(b.duration) - parseDuration(a.duration));
      } else if (sort === 'duration-asc') {
        list = [...list].sort((a, b) => parseDuration(a.duration) - parseDuration(b.duration));
      }

      renderGrid(list);
      countEl.textContent = `${list.length} / ${allVideos.length} videos`;
    }

    // Fuentes de datos: cada una sirve su propio JSON generado por el scraper.
    const ENDPOINTS = { model: '/api/ph/videos.json', favorites: '/api/ph/favorites.json' };
    let currentSource = 'model';
    const tabs = [...document.querySelectorAll('#tabs .tab')];

    // Sincroniza fuente + filtros con la URL (sin recargar) para poder
    // compartir/recargar manteniendo el estado.
    function syncUrl() {
      const url = new URL(window.location.href);
      const set = (key, val) => { val ? url.searchParams.set(key, val) : url.searchParams.delete(key); };
      set('fuente', currentSource === 'model' ? '' : currentSource);
      set('q', searchEl.value.trim());
      set('canal', uploaderEl.value);
      set('calidad', qualityEl.value);
      set('orden', sortEl.value);
      window.history.replaceState(null, '', url);
    }

    function readUrl() {
      const p = new URLSearchParams(window.location.search);
      searchEl.value = p.get('q') || '';
      uploaderEl.value = p.get('canal') || '';
      qualityEl.value = p.get('calidad') || '';
      sortEl.value = p.get('orden') || '';
    }

    // Rellena el desplegable de canales con los uploaders únicos de la fuente
    // actual, preservando la selección si sigue existiendo.
    function populateUploaders() {
      const prev = uploaderEl.value;
      uploaderEl.length = 1; // conserva la opción "Todos los canales"
      const names = [...new Set(allVideos.map(v => v.uploader?.name).filter(Boolean))].sort();
      for (const name of names) {
        const opt = document.createElement('option');
        opt.value = name;
        opt.textContent = name;
        uploaderEl.appendChild(opt);
      }
      uploaderEl.value = prev; // queda '' si la opción ya no existe en esta fuente
    }

    function setActiveTab(src) {
      tabs.forEach(t => {
        const active = t.dataset.src === src;
        t.classList.toggle('bg-vs-pink', active);
        t.classList.toggle('border-vs-pink', active);
        t.classList.toggle('text-white', active);
        t.classList.toggle('bg-vs-surface', !active);
        t.classList.toggle('text-gray-300', !active);
      });
    }

    // Carga una fuente (model | favorites): trae su JSON, repuebla filtros y pinta.
    async function loadSource(src) {
      currentSource = ENDPOINTS[src] ? src : 'model';
      setActiveTab(currentSource);
      grid.innerHTML = '<p class="text-center text-gray-500">Cargando…</p>';
      try {
        const res = await fetch(ENDPOINTS[currentSource]);
        allVideos = await res.json();
        populateUploaders();
        applyFilter();
      } catch (err) {
        grid.innerHTML = '<p class="text-center text-red-500">No se pudieron cargar los videos.</p>';
      }
    }

    [searchEl, uploaderEl, qualityEl, sortEl].forEach(el => {
      const evt = el === searchEl ? 'input' : 'change';
      el.addEventListener(evt, () => { applyFilter(); syncUrl(); });
    });

    resetEl.addEventListener('click', () => {
      searchEl.value = '';
      uploaderEl.value = '';
      qualityEl.value = '';
      sortEl.value = '';
      applyFilter();
      syncUrl();
    });

    // Cambio de fuente: al cambiar de pestaña, reseteamos el filtro de canal
    // (los uploaders difieren entre fuentes) y recargamos.
    tabs.forEach(t => t.addEventListener('click', async () => {
      if (t.dataset.src === currentSource) return;
      uploaderEl.value = '';
      await loadSource(t.dataset.src);
      syncUrl();
    }));

    // Si el usuario navega atrás/adelante, reflejar fuente + filtros.
    // Cargamos la fuente primero (puebla los canales) y luego leemos la URL.
    window.addEventListener('popstate', async () => {
      const src = new URLSearchParams(window.location.search).get('fuente') || 'model';
      if (src !== currentSource) await loadSource(src);
      readUrl();
      applyFilter();
    });

    (async () => {
      try {
        const initial = new URLSearchParams(window.location.search).get('fuente') || 'model';
        await loadSource(initial); // puebla canales de la fuente
        readUrl();                 // ahora las opciones existen → fija filtros de la URL
        applyFilter();
      } catch (err) {
        grid.innerHTML = '<p class="text-center text-red-500">No se pudieron cargar los videos.</p>';
      }
    })();

    function loadStreams(streams) {
      if (hls) { hls.destroy(); hls = null; }
      if (!streams || !streams.length) {
        titleEl.textContent = (currentVideo?.title || '') + ' — sin streams disponibles';
        return;
      }

      // Priorizamos HLS (master.m3u8). Los streams "mp4" de Pornhub no son
      // archivos: su videoUrl apunta a /video/get_media (devuelve JSON), así que
      // no se pueden poner en videoEl.src. Solo usamos mp4 si es un .mp4 real.
      const m3u8 = streams.find(s => s.videoUrl && s.videoUrl.includes('.m3u8'));
      if (m3u8) {
        if (Hls.isSupported()) {
          hls = new Hls();
          hls.loadSource(proxied(m3u8.videoUrl));
          hls.attachMedia(videoEl);
          hls.on(Hls.Events.ERROR, (_e, data) => {
            if (data.fatal) {
              titleEl.textContent = (currentVideo?.title || '') +
                ' — el stream caducó o no está disponible. Usa «Abrir en Pornhub».';
            }
          });
        } else if (videoEl.canPlayType('application/vnd.apple.mpegurl')) {
          videoEl.src = proxied(m3u8.videoUrl); // Safari reproduce HLS nativo
        }
        return;
      }

      const realMp4 = streams.find(s => s.videoUrl && /\.mp4(\?|$)/.test(s.videoUrl));
      if (realMp4) {
        videoEl.src = proxied(realMp4.videoUrl);
        return;
      }

      titleEl.textContent = (currentVideo?.title || '') + ' — sin streams reproducibles';
    }

    async function playVideo(video) {
      currentVideo = video;
      titleEl.textContent = video.title + ' — cargando…';
      modal.classList.remove('hidden');
      modal.classList.add('flex');

      if (hls) { hls.destroy(); hls = null; }
      videoEl.removeAttribute('src');

      // Las URLs guardadas en videos.json caducan (~minutos). Pedimos streams
      // frescos en el momento del click; si el endpoint falla, usamos las del JSON.
      const reqId = ++playToken;
      try {
        const res = await fetch(`/api/ph/stream.json?vkey=${encodeURIComponent(video.vkey)}`);
        const data = await res.json();
        if (reqId !== playToken) return; // el usuario abrió otro video / cerró
        titleEl.textContent = video.title;
        loadStreams(data.streams && data.streams.length ? data.streams : video.streams);
      } catch (err) {
        if (reqId !== playToken) return;
        titleEl.textContent = video.title;
        loadStreams(video.streams);
      }
    }

    openBtn.addEventListener('click', () => {
      if (currentVideo && currentVideo.pageUrl) {
        window.open(currentVideo.pageUrl, '_blank');
      }
    });

    function closeModal() {
      playToken++; // invalida cualquier fetch de stream en curso
      if (hls) hls.destroy();
      videoEl.pause();
      videoEl.src = '';
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    document.getElementById('close').addEventListener('click', closeModal);
    modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
  </script>
</body>
</html>
