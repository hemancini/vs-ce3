---
// Scraper SSR principal: en cada request scrapea Pornhub en vivo (model/favorites)
// y renderiza la grilla. La lógica de grilla, filtros y reproductor vive en el
// componente reutilizable <VideoGrid>, compartido con /ph/model/<x>,
// /ph/pornstar/<x>, etc.
//
// Parámetros (GET):
//   ?fuente=home|favorites    fuente a scrapear (default: home)
//   ?paginas=N                páginas de catálogo a recorrer (1..20, default: 1)
//   ?q=texto                  filtro por título (server-side)
//   ?streams=1                además extrae los streams de cada video (lento)
import Layout from "../../layouts/Ph.astro";
import PhHeader from "../../components/ph/PhHeader.astro";
import PhScraperControls from "../../components/ph/PhScraperControls.astro";
import PhCategoryChips from "../../components/ph/PhCategoryChips.astro";
import VideoGrid from "../../components/ph/VideoGrid.astro";
import { scrapeSource, SOURCES } from "../../lib/ph/scraper.js";

export const prerender = false;

const env = (Astro.locals as any)?.runtime?.env;

const params = Astro.url.searchParams;
const source = SOURCES[params.get("fuente") ?? ""] ? params.get("fuente") : "home";
const pages = Math.min(Math.max(parseInt(params.get("paginas") || "1", 10) || 1, 1), 20);
const q = (params.get("q") || "").trim();
const withStreams = params.get("streams") === "1";

let videos = [];
let totalPages = 0;
let searches = [];
let error = null;
const startedAt = Date.now();

try {
  const result = await scrapeSource({ source, maxPages: pages, withStreams, env });
  videos = result.videos;
  totalPages = result.totalPages;
  searches = result.searches ?? [];
} catch (e) {
  error = e.message;
}

// Estado de las cookies para mostrar en el panel editor
let cookieFromKV = false;
let cookieCount = 0;
try {
  const raw = await env?.VS_C3_KV?.get("ph:cookies");
  if (raw) { cookieFromKV = true; cookieCount = JSON.parse(raw).length; }
} catch {}

const elapsed = ((Date.now() - startedAt) / 1000).toFixed(1);
---

<Layout title="LustHub - Scraper SSR">
  <PhHeader
    title="🕷️ LustHub - Scraper SSR"
    stats={error ? "Error al scrapear" : `${videos.length} videos · ${elapsed}s · ${totalPages} págs.`}
    cookieFromKV={cookieFromKV}
    cookieCount={cookieCount}
    nav={["pornstars", "categories"]}
    showTabs
  >
    <!-- Controles de scraping (recargan la página). -->
    <PhScraperControls
      pages={pages}
      withStreams={withStreams}
      q={q}
      action="/ph"
      hidden={[{ name: "fuente", value: source ?? "home" }]}
    />
  </PhHeader>

  {/* Chips de Búsquedas de Tendencia de la portada (culos enormes, milica xxx, …). */}
  <PhCategoryChips chips={searches} />

  <VideoGrid
    videos={videos}
    totalPages={totalPages}
    nextPage={pages + 1}
    source={source}
    withStreams={withStreams}
    q={q}
    error={error}
  />
</Layout>
