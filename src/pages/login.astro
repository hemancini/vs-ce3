---
export const prerender = false;

// Si ya tiene sesión válida → redirigir al destino o a /
import { verifyToken, COOKIE_NAME } from "@/lib/auth";

const env = (Astro.locals as App.Locals).runtime?.env;
const apiKey   = env?.API_KEY ?? import.meta.env.API_KEY ?? "";
const token    = Astro.cookies.get(COOKIE_NAME)?.value;
const noSession = Astro.url.searchParams.get("nosession") === "1";

// Solo auto-redirigir si la sesión de pestaña sigue activa (no viene de un logout por sessionStorage)
if (!noSession && token && apiKey && (await verifyToken(token, apiKey))) {
  const redirectTo = Astro.url.searchParams.get("redirect") ?? "/";
  return Astro.redirect(redirectTo, 302);
}

const error    = Astro.url.searchParams.get("error");
const redirect = Astro.url.searchParams.get("redirect") ?? "/";
---
<!DOCTYPE html>
<html lang="es" class="bg-vs-bg">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0f0f0f" />
  <title>Acceso · vs</title>
</head>
<body class="min-h-screen bg-vs-bg text-gray-300 font-sans flex items-center justify-center p-6">

  <div class="w-full max-w-sm">
    <!-- Cabecera -->
    <div class="mb-8 text-center">
      <h1 class="text-2xl font-bold text-white tracking-tight">vs</h1>
      <p class="text-sm text-gray-500 mt-1">Introduce la contraseña de acceso</p>
    </div>

    <!-- Formulario -->
    <form
      id="login-form"
      method="POST"
      action="/api/auth/login"
      class="bg-vs-surface border border-vs-border rounded-xl p-6 flex flex-col gap-4 shadow-lg"
      aria-label="Formulario de acceso"
      novalidate
    >
      <input type="hidden" name="redirect" value={redirect} />

      {error && (
        <div
          role="alert"
          class="text-sm text-red-400 bg-red-950/40 border border-red-800 rounded-lg px-4 py-2.5"
        >
          Contraseña incorrecta. Inténtalo de nuevo.
        </div>
      )}

      <div class="flex flex-col gap-1.5">
        <label for="apikey" class="text-xs font-semibold text-gray-400 uppercase tracking-widest">
          Contraseña
        </label>
        <input
          id="apikey"
          name="apiKey"
          type="password"
          autocomplete="current-password"
          required
          autofocus
          placeholder="••••••••••••"
          class="bg-vs-bg border border-vs-border rounded-lg px-4 py-2.5 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
          aria-describedby={error ? "login-error" : undefined}
        />
      </div>

      <button
        type="submit"
        class="w-full bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white font-semibold rounded-lg px-4 py-2.5 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
      >
        Entrar
      </button>
    </form>
  </div>

</body>
</html>
