{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["@cloudflare/workers-types/2023-07-01", "@astrojs/cloudflare"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
